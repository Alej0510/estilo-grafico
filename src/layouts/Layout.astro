---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppBubble from "../components/WhatsAppBubble.astro";
import Seo from "../components/Seo.astro";
import JsonLd from "../components/JsonLd.astro";
import { ClientRouter } from "astro:transitions";
import { SITE } from "../data/site";
import { localBusinessSchema } from "../lib/structured-data";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title: string;
  description?: string;
  path?: string;
  image?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown>[];
}

const {
  title,
  description = SITE.description,
  path = "/",
  image,
  noindex = false,
  structuredData = [],
} = Astro.props;

const jsonLd = [localBusinessSchema(), ...structuredData];
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={SITE.themeColor} />
    <link rel="icon" type="image/png" href={SITE.logo} />
    <Seo
      title={title}
      description={description}
      path={path}
      image={image}
      noindex={noindex}
    />
    <JsonLd data={jsonLd} />
    <ClientRouter />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Sora:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <Analytics />
  </head>
  <body
    class="bg-zinc-50 text-zinc-800 antialiased overflow-x-hidden selection:bg-brand-500 selection:text-zinc-900"
  >
    <Header />
    <slot />
    <Footer />
    <WhatsAppBubble />
  </body>
</html>
