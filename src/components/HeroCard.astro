---
interface Props {
  class?: string;
  padding?: string;
  /** Soft brand/amber glow orbs behind content */
  glow?: boolean;
  rounded?: "default" | "hero";
  style?: string;
}

const {
  class: className = "",
  padding = "p-6 sm:p-8 lg:p-12 xl:p-14",
  glow = false,
  rounded = "default",
  style,
} = Astro.props;

const radius =
  rounded === "hero"
    ? "rounded-4xl sm:rounded-[2.5rem] lg:rounded-[3.5rem]"
    : "rounded-4xl sm:rounded-[2.5rem] lg:rounded-[3rem]";
---

<div
  class:list={[
    "relative bg-white border border-zinc-200/70 shadow-2xl shadow-black/20 overflow-hidden",
    radius,
    className,
  ]}
  style={style}
>
  <div
    class="absolute inset-0 bg-linear-to-br from-zinc-50/80 via-white to-brand-50/20 pointer-events-none"
  >
  </div>
  <div
    class="absolute top-0 left-[8%] right-[8%] h-px bg-linear-to-r from-transparent via-brand-400/40 to-transparent pointer-events-none"
  >
  </div>

  {
    glow && (
      <>
        <div
          class="absolute -top-24 -right-24 w-64 h-64 bg-brand-500/10 rounded-full blur-3xl pointer-events-none"
          aria-hidden="true"
        />
        <div
          class="absolute -bottom-16 -left-16 w-48 h-48 bg-amber-500/10 rounded-full blur-3xl pointer-events-none"
          aria-hidden="true"
        />
      </>
    )
  }

  <div class:list={["relative", padding]}>
    <slot />
  </div>
</div>
