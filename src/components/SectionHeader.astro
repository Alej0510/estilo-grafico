---
interface Props {
  eyebrow: string;
  description?: string;
  align?: "center" | "left";
  /** Bilateral lines flanking the eyebrow (centered sections) */
  decorated?: boolean;
  id?: string;
  class?: string;
}

const {
  eyebrow,
  description,
  align = "center",
  decorated = false,
  id,
  class: className = "",
} = Astro.props;

const isCenter = align === "center";
---

<header
  class:list={[
    isCenter ? "text-center max-w-3xl mx-auto" : "max-w-2xl",
    className,
  ]}
>
  {
    isCenter && decorated ? (
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="block w-8 h-px bg-brand-500" aria-hidden="true" />
        <span class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-600">
          {eyebrow}
        </span>
        <span class="block w-8 h-px bg-brand-500" aria-hidden="true" />
      </div>
    ) : (
      <div
        class:list={[
          "flex items-center gap-3",
          isCenter ? "justify-center mb-3" : "mb-6",
        ]}
      >
        {!isCenter && (
          <span class="block w-8 h-px bg-brand-500" aria-hidden="true" />
        )}
        <span class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-600">
          {eyebrow}
        </span>
      </div>
    )
  }

  <h2
    id={id}
    class:list={[
      "font-extrabold text-zinc-900 tracking-tight leading-tight",
      isCenter
        ? "text-3xl sm:text-4xl lg:text-[2.75rem]"
        : "text-3xl sm:text-4xl xl:text-[2.75rem] leading-[1.08]",
    ]}
  >
    <slot />
  </h2>

  {
    description && (
      <p
        class:list={[
          "text-lg text-zinc-500 leading-relaxed",
          isCenter ? "mt-4 max-w-2xl mx-auto" : "mt-2",
        ]}
      >
        {description}
      </p>
    )
  }
</header>
