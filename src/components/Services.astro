---
const services = [
  {
    id: 1,
    title: 'Etiquetas y empaques',
    description: 'Soluciones de empaquetado premium que hacen destacar tu producto en el estante.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
    color: 'from-yellow-400 to-amber-500'
  },
  {
    id: 2,
    title: 'Material Impreso litográfico',
    description: 'Impresión de alta precisión para catálogos, revistas y papelería corporativa.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    color: 'from-amber-500 to-orange-500'
  },
  {
    id: 3,
    title: 'Impresión a gran formato',
    description: 'Avisos, pendones y vinilos de alto impacto visual para exteriores e interiores.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    color: 'from-orange-500 to-yellow-400'
  },
  {
    id: 4,
    title: 'Diseño e Imagen',
    description: 'Creamos la identidad visual perfecta que conecta con tu audiencia objetivo.',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
    color: 'from-yellow-500 to-amber-600'
  }
];
---

<section id="productos" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-brand-600 font-semibold tracking-wide uppercase text-sm mb-3">Nuestros Servicios</h2>
      <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-zinc-900 sm:text-4xl">
        Impresión y diseño que elevan tu marca
      </p>
      <p class="mt-4 max-w-2xl text-xl text-zinc-500 mx-auto">
        Ofrecemos un portafolio completo de soluciones gráficas con tecnología de punta y acabados premium.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <div class="group relative bg-zinc-50 rounded-2xl p-8 hover:bg-white hover:shadow-2xl hover:shadow-zinc-200/50 transition-all duration-300 border border-zinc-100 hover:border-brand-200 overflow-hidden hover:-translate-y-2">
          <!-- Hover Gradient Background -->
          <div class={`absolute inset-0 bg-gradient-to-br ${service.color} opacity-0 group-hover:opacity-5 transition-opacity duration-300`}></div>
          
          <div class="relative z-10">
            <div class={`inline-flex items-center justify-center p-3 rounded-xl bg-gradient-to-br ${service.color} text-white mb-6 shadow-lg group-hover:scale-110 transition-transform duration-300`}>
              <Fragment set:html={service.icon} />
            </div>
            
            <h3 class="text-xl font-bold text-zinc-900 mb-3 group-hover:text-brand-600 transition-colors">
              {service.title}
            </h3>
            
            <p class="text-zinc-600 leading-relaxed">
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
