---
const services = [
  {
    id: 1,
    title: 'Etiquetas y empaques',
    description: 'Soluciones de empaquetado premium que hacen destacar tu producto en el estante.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
    color: 'from-yellow-400 to-amber-500',
    number: '01'
  },
  {
    id: 2,
    title: 'Material Impreso litográfico',
    description: 'Impresión de alta precisión para catálogos, revistas y papelería corporativa.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    color: 'from-amber-500 to-orange-500',
    number: '02'
  },
  {
    id: 3,
    title: 'Impresión a gran formato',
    description: 'Avisos, pendones y vinilos de alto impacto visual para exteriores e interiores.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    color: 'from-orange-500 to-yellow-400',
    number: '03'
  },
  {
    id: 4,
    title: 'Diseño e Imagen',
    description: 'Creamos la identidad visual perfecta que conecta con tu audiencia objetivo.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
    color: 'from-yellow-500 to-amber-600',
    number: '04'
  }
];
---

<section id="productos" class="py-10 lg:py-18 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-white via-zinc-50/50 to-white"></div>
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 mb-10">
        <h2 class="text-xl font-medium text-brand-700 tracking-wide">Nuestros Servicios</h2>
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-zinc-900 leading-tight">
        Impresión y diseño que
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-500 to-brand-600"> elevan tu marca</span>
      </h2>
      <p class="mt-6 text-lg text-zinc-500 max-w-2xl mx-auto leading-relaxed">
        Nos especializamos en ofrecer servicios de impresión gráfica de alta
        calidad y soluciones integrales de diseño gráfico utilizando tecnología
        avanzada para garantizar precisión y resultados creativos.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {services.map((service, index) => (
        <div
          class="group relative bg-white rounded-3xl p-8 lg:p-10 hover:shadow-2xl hover:shadow-zinc-200/50 transition-all duration-500 border border-zinc-100 hover:border-brand-200/50 overflow-hidden"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Background gradient on hover -->
          <div class={`absolute inset-0 bg-gradient-to-br ${service.color} opacity-0 group-hover:opacity-[0.03] transition-opacity duration-500`}></div>
          
          <!-- Corner accent -->
          <div class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl ${service.color} opacity-0 group-hover:opacity-10 transition-opacity duration-500 rounded-bl-[100px]`}></div>
          
          <div class="relative z-10">
            <div class="flex items-start justify-between mb-8">
              <div class={`inline-flex items-center justify-center p-4 rounded-2xl bg-gradient-to-br ${service.color} text-white shadow-lg shadow-${service.color.split(' ')[0].replace('from-', '')}/20 group-hover:scale-105 group-hover:shadow-xl transition-all duration-500`}>
                <Fragment set:html={service.icon} />
              </div>
              <span class="text-6xl font-extrabold text-zinc-100 group-hover:text-brand-100 transition-colors duration-500 select-none">
                {service.number}
              </span>
            </div>
            
            <h3 class="text-2xl font-bold text-zinc-900 mb-4 group-hover:text-brand-600 transition-colors duration-300">
              {service.title}
            </h3>
            
            <p class="text-zinc-500 leading-relaxed mb-6">
              {service.description}
            </p>
            
            <div class="flex items-center gap-2 text-sm font-medium text-brand-600 opacity-0 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-500">
              <a href="#contacto">Conocer más</a>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
