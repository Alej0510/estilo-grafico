---
import { products } from "../data/products";
---

<section id="productos" class="py-10 lg:py-18 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-white via-zinc-50/50 to-white"></div>
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 mb-10">
        <h2 class="text-xl font-medium text-brand-700 tracking-wide">Nuestros Servicios</h2>
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-zinc-900 leading-tight">
        Impresión y diseño que
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-500 to-brand-600"> elevan tu marca</span>
      </h2>
      <p class="mt-6 text-lg text-zinc-500 max-w-2xl mx-auto leading-relaxed">
        Ofrecemos una amplia gama de servicios y productos diseñados para
        satisfacer todas tus necesidades de impresión y diseño gráfico.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {products.map((product, index) => (
        <a
          href={`/productos/${product.slug}`}
          class="group relative bg-white rounded-3xl p-8 lg:p-10 hover:shadow-2xl hover:shadow-zinc-200/50 transition-all duration-500 border border-zinc-100 hover:border-brand-200/50 overflow-hidden block"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Background gradient on hover -->
          <div class={`absolute inset-0 bg-gradient-to-br ${product.color} opacity-0 group-hover:opacity-[0.03] transition-opacity duration-500`}></div>
          
          <!-- Corner accent -->
          <div class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl ${product.color} opacity-0 group-hover:opacity-10 transition-opacity duration-500 rounded-bl-[100px]`}></div>
          
          <div class="relative z-10">
            <div class="flex items-start justify-between mb-8">
              <div class={`inline-flex items-center justify-center p-4 rounded-2xl bg-gradient-to-br ${product.color} text-white shadow-lg group-hover:scale-105 group-hover:shadow-xl transition-all duration-500`}>
                <Fragment set:html={product.icon} />
              </div>
              <span class="text-6xl font-extrabold text-zinc-100 group-hover:text-brand-100 transition-colors duration-500 select-none">
                {product.number}
              </span>
            </div>
            
            <h3 class="text-2xl font-bold text-zinc-900 mb-4 group-hover:text-brand-600 transition-colors duration-300">
              {product.title}
            </h3>
            
            <p class="text-zinc-500 leading-relaxed mb-6">
              {product.description}
            </p>
            
            <div class="flex items-center gap-2 text-sm font-medium text-brand-600 opacity-0 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-500">
              <span>Conocer más</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
