---

---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-gradient-to-b from-zinc-50 via-white to-zinc-100/80"
    >
    </div>

    <!-- Geometric grid pattern -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>

    <!-- Gradient orbs -->
    <div
      class="absolute top-1/4 -left-20 w-[500px] h-[500px] bg-brand-500/8 rounded-full blur-[100px] mix-blend-multiply"
    >
    </div>
    <div
      class="absolute bottom-1/4 -right-20 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-[100px] mix-blend-multiply"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-100/20 rounded-full blur-[120px]"
    >
    </div>

    <!-- Top border gradient -->
    <div
      class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-500/20 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-40"
  >
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left Content -->
      <div class="text-left">
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 py-2 mb-8 animate-fade-in-up"
          style="animation-delay: 0.1s;"
        >
          <span class="text-sm font-bold text-brand-500 tracking-wide"
            >Expertos en impresión</span
          >
        </div>

        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-zinc-900 tracking-tight leading-[0.95] mb-8 animate-fade-in-up"
          style="animation-delay: 0.2s;"
        >
          Transformamos
          <br />
          <span class="relative inline-block">
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-brand-500 via-brand-600 to-amber-600"
            >
              tus ideas
            </span>
            <svg
              class="absolute -bottom-2 left-0 w-full"
              viewBox="0 0 200 8"
              fill="none"
            >
              <path
                d="M1 5.5C47 2.5 100 1.5 199 5.5"
                stroke="url(#gradient)"
                stroke-width="3"
                stroke-linecap="round"></path>
              <defs>
                <linearGradient id="gradient" x1="0" y1="0" x2="200" y2="0">
                  <stop offset="0%" stop-color="#eab308" stop-opacity="0"
                  ></stop>
                  <stop offset="50%" stop-color="#eab308"></stop>
                  <stop offset="100%" stop-color="#ca8a04" stop-opacity="0"
                  ></stop>
                </linearGradient>
              </defs>
            </svg>
          </span>
          <br />
          <span class="text-zinc-800">en impresiones</span>
          <br />
          <span class="text-zinc-600 text-4xl md:text-5xl lg:text-6xl"
            >de calidad</span
          >
        </h1>

        <p
          class="text-lg md:text-xl text-zinc-500 max-w-lg mb-10 leading-relaxed animate-fade-in-up"
          style="animation-delay: 0.3s;"
        >
          Descubre nuestras soluciones personalizadas y destaca con nuestro
          servicio excepcional. Expertos en impresión desde cero.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 animate-fade-in-up"
          style="animation-delay: 0.4s;"
        >
          <a
            href="#productos"
            class="group relative inline-flex items-center justify-center px-8 py-4 overflow-hidden rounded-2xl font-bold text-zinc-900 transition-all duration-500 hover:shadow-2xl hover:shadow-brand-500/25"
          >
            <div
              class="absolute inset-0 bg-gradient-to-r from-brand-500 to-brand-600 transition-all duration-500 group-hover:scale-105"
            >
            </div>
            <div
              class="absolute inset-0 bg-gradient-to-r from-brand-400 to-brand-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            >
            </div>
            <span
              class="relative z-10 flex items-center gap-3 uppercase tracking-wider text-sm"
            >
              Explorar Servicios
              <svg
                class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>

      <!-- Right Visual Element -->
      <div
        class="relative hidden lg:block animate-fade-in-up"
        style="animation-delay: 0.6s;"
      >
        <div class="relative">
          <!-- Main visual card -->
          <div
            class="relative bg-gradient-to-br from-zinc-900 to-zinc-800 rounded-3xl p-8 shadow-2xl shadow-zinc-900/20 overflow-hidden"
          >
            <div
              class="absolute inset-0 bg-gradient-to-br from-brand-500/10 to-transparent"
            >
            </div>
            <div
              class="absolute top-0 right-0 w-32 h-32 bg-brand-500/20 rounded-full blur-3xl"
            >
            </div>

            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <div class="w-3 h-3 rounded-full bg-green-400"></div>
              </div>

              <div class="space-y-4">
                <div class="h-4 bg-white/10 rounded-full w-3/4"></div>
                <div class="h-4 bg-white/10 rounded-full w-1/2"></div>
                <div class="h-4 bg-brand-500/30 rounded-full w-5/6"></div>
                <div class="h-4 bg-white/10 rounded-full w-2/3"></div>
              </div>

              <div class="mt-8 grid grid-cols-2 gap-4">
                <div class="bg-white/5 rounded-2xl p-4 border border-white/10">
                  <div
                    class="w-12 h-12 bg-brand-500/20 rounded-xl mb-3 flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-brand-400"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      ></path>
                    </svg>
                  </div>
                  <div class="h-2 bg-white/10 rounded-full w-full mb-2"></div>
                  <div class="h-2 bg-white/10 rounded-full w-2/3"></div>
                </div>
                <div class="bg-white/5 rounded-2xl p-4 border border-white/10">
                  <div
                    class="w-12 h-12 bg-amber-500/20 rounded-xl mb-3 flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-amber-400"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
                      ></path>
                    </svg>
                  </div>
                  <div class="h-2 bg-white/10 rounded-full w-full mb-2"></div>
                  <div class="h-2 bg-white/10 rounded-full w-2/3"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div
            class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-4 shadow-xl shadow-zinc-200/50 border border-zinc-100"
          >
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center"
              >
                <svg
                  class="w-5 h-5 text-green-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <div class="text-sm font-bold text-zinc-900">
                  Calidad Premium
                </div>
                <div class="text-xs text-zinc-500">100% Garantizado</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
