---
import { Image } from "astro:assets";
import { WHATSAPP_URL } from "../data/products";
import Arrow from "./icons/Arrow.astro";
import heroImage from "../assets/hero.webp";
import heroBg from "../assets/hero-bg.jpeg";
---

<section
  class="relative min-h-screen flex items-center overflow-hidden pt-32 pb-16 sm:pt-36 sm:pb-20 lg:pt-28 lg:pb-28"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroBg}
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/20"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <!-- ========== MAIN HERO BOX ========== -->
    <div
      class="relative bg-white rounded-4xl sm:rounded-[2.5rem] lg:rounded-[3.5rem] border border-zinc-200/70 shadow-2xl shadow-zinc-200/40 overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-linear-to-br from-zinc-50/80 via-white to-zinc-50/40"
      >
      </div>

      <div
        class="relative grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 xl:gap-16 items-center p-6 sm:p-8 lg:p-12 xl:p-16"
      >
        <!-- Left: Content -->
        <div class="min-w-0 flex flex-col justify-center order-2 lg:order-1">
          <p
            class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-600 mb-4 animate-fade-in-up"
            style="animation-delay: 0.05s;"
          >
            Litografía e impresión gráfica
          </p>
          <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
            <h1
              class="text-[2rem] leading-[1.08] sm:text-4xl sm:leading-[1.08] md:text-5xl md:leading-[1.08] lg:text-[2.75rem] lg:leading-[1.08] xl:text-6xl xl:leading-[1.05] font-extrabold text-zinc-900 tracking-[-0.02em] uppercase wrap-break-word"
            >
              Hacemos<br />
              <span
                class="text-transparent bg-clip-text bg-linear-to-r from-brand-500 via-brand-600 to-amber-600"
              >
                tus ideas
              </span>
              realidad
            </h1>
          </div>

          <div class="flex flex-col gap-6 mt-6 sm:mt-8">
            <p
              class="text-base sm:text-lg lg:text-xl text-zinc-500 max-w-xl leading-relaxed animate-fade-in-up"
              style="animation-delay: 0.25s;"
            >
              En Estilo Gráfico transformamos tu marca con litografía, impresión
              y diseño profesional en Medellín. Calidad desde cero, acabados
              premium y entrega garantizada.
            </p>

            <div
              class="self-start animate-fade-in-up"
              style="animation-delay: 0.4s;"
            >
              <a
                href="#productos"
                class="relative inline-flex items-center justify-center px-7 py-3.5 overflow-hidden rounded-full font-bold text-sm sm:text-base text-zinc-900 group"
              >
                <div
                  class="absolute inset-0 bg-linear-to-r from-brand-500 to-brand-600 transition-transform duration-500 group-hover:scale-105"
                >
                </div>
                <div
                  class="absolute inset-0 bg-linear-to-r from-brand-400 to-brand-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                >
                </div>
                <span class="relative z-10 flex items-center gap-2">
                  Ver servicios
                  <span
                    class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5"
                  >
                    <Arrow to="right" class="w-4 h-4" />
                  </span>
                </span>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Image -->
        <div
          class="relative min-w-0 order-1 lg:order-2 w-full aspect-4/3 sm:aspect-5/4 lg:aspect-auto lg:h-[420px] xl:h-[480px] rounded-3xl sm:rounded-4xl overflow-hidden animate-fade-in-up"
          style="animation-delay: 0.3s;"
        >
          <Image
            src={heroImage}
            alt="Litografía e impresión profesional en Medellín — Estilo Gráfico"
            class="w-full h-full object-cover object-center"
            loading="eager"
            fetchpriority="high"
          />
          <div
            class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl sm:rounded-4xl pointer-events-none"
          >
          </div>
        </div>
      </div>
    </div>

    <!-- ========== QUÉ HACEMOS BANNER ========== -->
    <div
      class="relative mt-3 sm:mt-4 lg:mt-6 rounded-3xl sm:rounded-4xl lg:rounded-[2.5rem] overflow-hidden border border-zinc-200/70 bg-white shadow-xl shadow-zinc-200/30 animate-fade-in-up"
      style="animation-delay: 0.35s;"
    >
      <div
        class="absolute inset-0 bg-linear-to-br from-brand-50/60 via-white to-amber-50/40 pointer-events-none"
      >
      </div>
      <div
        class="absolute -top-24 -right-24 w-64 h-64 bg-brand-500/10 rounded-full blur-3xl pointer-events-none"
      >
      </div>
      <div
        class="absolute -bottom-16 -left-16 w-48 h-48 bg-amber-500/10 rounded-full blur-3xl pointer-events-none"
      >
      </div>
      <div
        class="absolute top-0 left-[8%] right-[8%] h-px bg-linear-to-r from-transparent via-brand-400/40 to-transparent"
      >
      </div>

      <div
        class="relative flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 sm:gap-8 p-6 sm:p-8 lg:p-9 xl:p-10"
      >
        <div class="max-w-2xl">
          <h2
            class="text-xl sm:text-2xl font-extrabold text-zinc-900 tracking-tight leading-[1.15] mb-4"
          >
            ¿Qué hacemos en Estilo Gráfico?
          </h2>

          <p class="text-base sm:text-lg text-zinc-600 leading-relaxed">
            Litografía e impresión gráfica de alta calidad en Medellín: desde
            tarjetas de presentación hasta gran formato, con precisión y
            creatividad en cada proyecto.
          </p>
        </div>

        <div class="w-full sm:w-auto shrink-0">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="relative flex w-full sm:w-auto sm:inline-flex items-center justify-center px-7 py-3.5 overflow-hidden rounded-full font-bold text-sm sm:text-base text-white group"
          >
            <div
              class="absolute inset-0 bg-[#212120] transition-transform duration-500 group-hover:scale-105"
            >
            </div>
            <div
              class="absolute inset-0 bg-[#2d2d2c] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            >
            </div>
            <span class="relative z-10 flex items-center gap-2">
              Contáctanos
              <span
                class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5"
              >
                <Arrow to="right" class="w-4 h-4" />
              </span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
