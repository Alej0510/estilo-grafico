---
const features = [
  {
    icon: `<svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    num: "01.",
    title: "Impresión de alto impacto visual",
  },
  {
    icon: `<svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
    num: "02.",
    title: "Diseño profesional que conecta con tu audiencia",
  },
  {
    icon: `<svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
    num: "03.",
    title: "Acabados premium con tecnología de punta",
  },
  {
    icon: `<svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    num: "04.",
    title: "Entrega rápida sin sacrificar calidad",
  },
];
---

<section
  class="relative min-h-screen flex items-center overflow-hidden pt-32 pb-16 sm:pt-36 sm:pb-20 lg:pt-22 lg:pb-28"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-gradient-to-b from-zinc-50 via-white to-zinc-100/80"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.02]"
      style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.12) 1px, transparent 0); background-size: 32px 32px;"
    >
    </div>
    <div
      class="absolute top-1/3 -left-32 w-[300px] sm:w-[400px] lg:w-[600px] h-[300px] sm:h-[400px] lg:h-[600px] bg-brand-500/6 rounded-full blur-[100px] sm:blur-[120px]"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-[200px] sm:w-[300px] lg:w-[400px] h-[200px] sm:h-[300px] lg:h-[400px] bg-amber-500/5 rounded-full blur-[80px] sm:blur-[100px]"
    >
    </div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <!-- ========== MAIN HERO BOX ========== -->
    <div
      class="relative bg-white rounded-[2rem] sm:rounded-[2.5rem] lg:rounded-[3.5rem] border border-zinc-200/70 shadow-2xl shadow-zinc-200/40"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-zinc-50/80 via-white to-zinc-50/40"
      >
      </div>

      <div class="relative p-6 sm:p-8 lg:p-16 xl:p-20">
        <!-- H1 -->
        <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
          <h1
            class="text-[2.25rem] leading-[1.05] sm:text-5xl sm:leading-[1.05] md:text-6xl md:leading-[1.05] lg:text-7xl lg:leading-[1.05] xl:text-8xl xl:leading-[1.05] font-extrabold text-zinc-900 tracking-[-0.02em] uppercase"
          >
            <span class="sm:hidden">Transforma</span>
            <span class="hidden sm:inline">Transformamos</span><br />
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-brand-500 via-brand-600 to-amber-600"
            >
              tus ideas
            </span>
          </h1>
        </div>

        <!-- Bottom row: subheadline + CTA -->
        <div
          class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 sm:gap-8 lg:gap-12 mt-4 sm:mt-8"
        >
          <p
            class="text-base sm:text-lg lg:text-xl text-zinc-500 max-w-xl leading-relaxed animate-fade-in-up"
            style="animation-delay: 0.25s;"
          >
            Soluciones de impresión y diseño profesional que transforman tu
            marca. Expertos en calidad desde cero, con acabados premium y
            entrega garantizada.
          </p>

          <div
            class="flex-shrink-0 self-end sm:self-auto animate-fade-in-up"
            style="animation-delay: 0.4s;"
          >
            <a
              href="/productos"
              class="group relative flex items-center justify-center w-20 h-20 sm:w-24 sm:h-24 lg:w-28 lg:h-28 rounded-full bg-zinc-900 hover:bg-zinc-800 transition-all duration-500 hover:scale-105 hover:shadow-2xl hover:shadow-zinc-900/20"
              aria-label="Explorar servicios"
            >
              <svg
                class="w-7 h-7 sm:w-8 sm:h-8 lg:w-10 lg:h-10 text-white transition-transform duration-500 group-hover:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ========== FEATURE GRID ========== -->
    <div
      class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-6 mt-3 sm:mt-4 lg:mt-6"
    >
      {
        features.map((feature, index) => (
          <div
            class="relative bg-white rounded-[1.5rem] sm:rounded-[2rem] lg:rounded-[2.5rem] p-5 sm:p-7 lg:p-8 border border-zinc-200/70 hover:border-brand-200/60 hover:shadow-xl hover:shadow-zinc-200/30 transition-all duration-500 group animate-fade-in-up"
            style={`animation-delay: ${0.2 + index * 0.1}s;`}
          >
            <div class="text-brand-600 mb-5 sm:mb-6 lg:mb-8">
              <Fragment set:html={feature.icon} />
            </div>

            <span class="inline-block px-2.5 py-1 sm:px-3 sm:py-1.5 text-[0.65rem] sm:text-xs font-bold text-brand-600 bg-brand-50 border border-brand-200 rounded-full mb-3 sm:mb-4 tracking-wider">
              {feature.num}
            </span>

            <h3 class="text-sm sm:text-base lg:text-lg font-bold text-zinc-900 leading-snug tracking-[-0.01em]">
              {feature.title}
            </h3>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
