---
import { WHATSAPP_URL } from "../data/products";
import WhatsApp from "./icons/WhatsApp.astro";
import Arrow from "./icons/Arrow.astro";
import Clock from "./icons/Clock.astro";
import Chat from "./icons/Chat.astro";
import Check from "./icons/Check.astro";

interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = "¿Listo para empezar tu proyecto?",
  subtext = "Cuéntanos tu idea y te ayudamos a hacerla realidad. Respuesta rápida, asesoría personalizada.",
} = Astro.props;

const highlights = [
  { label: "Respuesta en minutos", Icon: Clock },
  { label: "Asesoría personalizada", Icon: Chat },
  { label: "Cotización sin compromiso", Icon: Check },
] as const;
---

<section
  class="py-16 sm:py-20 lg:py-28 relative overflow-hidden"
  aria-labelledby="contact-banner-heading"
>
  <!-- Ambient accents -->
  <div
    class="absolute -top-24 right-[10%] w-72 h-72 bg-brand-500/8 rounded-full blur-[100px] pointer-events-none"
  >
  </div>
  <div
    class="absolute -bottom-16 left-[5%] w-56 h-56 bg-amber-500/6 rounded-full blur-[80px] pointer-events-none"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="contact-banner-card relative rounded-4xl sm:rounded-[2.5rem] lg:rounded-[3rem] overflow-hidden bg-white border border-zinc-200/70 shadow-2xl shadow-black/25"
    >
      <!-- Inner gradient wash -->
      <div
        class="absolute inset-0 bg-linear-to-br from-zinc-50/90 via-white to-brand-50/30 pointer-events-none"
      >
      </div>

      <!-- Top accent line -->
      <div
        class="absolute top-0 left-[8%] right-[8%] h-px bg-linear-to-r from-transparent via-brand-500/60 to-transparent"
      >
      </div>

      <div
        class="relative z-10 grid lg:grid-cols-12 gap-8 sm:gap-10 lg:gap-8 xl:gap-12 items-center p-6 sm:p-12 lg:p-14 xl:p-16"
      >
        <!-- Copy column -->
        <div class="lg:col-span-7 flex flex-col justify-center">
          <div
            class="banner-reveal flex items-center gap-3 mb-6"
            style="animation-delay: 0.05s;"
          >
            <span class="block w-8 h-px bg-brand-500"></span>
            <span
              class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-600"
            >
              Hablemos
            </span>
          </div>

          <h2
            id="contact-banner-heading"
            class="banner-reveal text-3xl sm:text-4xl xl:text-[2.75rem] font-extrabold text-zinc-900 tracking-tight leading-[1.08] mb-5"
            style="animation-delay: 0.12s;"
          >
            {headline}
          </h2>

          <p
            class="banner-reveal text-base sm:text-lg text-zinc-500 leading-relaxed max-w-[42ch] mb-8"
            style="animation-delay: 0.2s;"
          >
            {subtext}
          </p>

          <!-- Trust highlights -->
          <ul
            class="banner-reveal flex flex-col sm:flex-row sm:flex-wrap gap-3"
            style="animation-delay: 0.28s;"
            role="list"
          >
            {
              highlights.map(({ label, Icon }) => (
                <li class="inline-flex items-center gap-2 px-3.5 py-2 rounded-full bg-zinc-50 border border-zinc-200/80 text-sm text-zinc-600">
                  <span class="flex items-center justify-center w-5 h-5 rounded-full bg-brand-100 text-brand-600 shrink-0">
                    <Icon class="w-3 h-3" />
                  </span>
                  {label}
                </li>
              ))
            }
          </ul>
        </div>

        <!-- WhatsApp CTA card -->
        <div class="lg:col-span-5 min-w-0">
          <div
            class="banner-reveal relative rounded-3xl sm:rounded-[1.75rem] bg-zinc-900 p-6 sm:p-8 md:p-10 overflow-hidden group"
            style="animation-delay: 0.35s;"
          >
            <!-- Card glow -->
            <div
              class="absolute inset-0 bg-linear-to-br from-[#25D366]/10 via-transparent to-brand-500/5 pointer-events-none"
            >
            </div>
            <div
              class="absolute -top-12 -right-12 w-40 h-40 bg-[#25D366]/15 rounded-full blur-3xl pointer-events-none transition-opacity duration-500 group-hover:opacity-150"
            >
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-white/10 to-transparent"
            >
            </div>

            <div class="relative z-10 min-w-0">
              <!-- Status row -->
              <div class="flex items-center justify-between gap-3 mb-6 sm:mb-8">
                <div class="flex items-center gap-2 min-w-0">
                  <span class="relative flex h-2 w-2 shrink-0">
                    <span
                      class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#25D366] opacity-60"
                    ></span>
                    <span
                      class="relative inline-flex rounded-full h-2 w-2 bg-[#25D366]"
                    ></span>
                  </span>
                  <span
                    class="text-[10px] sm:text-[11px] font-bold text-[#25D366] uppercase tracking-[0.12em] sm:tracking-[0.15em] truncate"
                  >
                    <span class="sm:hidden">En línea</span>
                    <span class="hidden sm:inline">Disponible ahora</span>
                  </span>
                </div>
                <div
                  class="hidden sm:flex items-center justify-center w-10 h-10 rounded-xl bg-[#25D366]/15 border border-[#25D366]/25 shrink-0"
                  aria-hidden="true"
                >
                  <WhatsApp class="w-5 h-5 text-[#25D366]" />
                </div>
              </div>

              <p class="text-xs sm:text-sm font-medium text-zinc-400 mb-1">
                Escríbenos por WhatsApp
              </p>
              <a
                href="tel:+573216426377"
                class="block text-[1.35rem] sm:text-2xl md:text-3xl font-extrabold text-white tracking-tight leading-none mb-6 sm:mb-8 whitespace-nowrap transition-colors duration-200 hover:text-brand-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900 rounded-sm"
              >
                +57 321 642 6377
              </a>

              <a
                href={WHATSAPP_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="group/btn relative inline-flex items-center justify-center gap-2 sm:gap-2.5 w-full px-4 sm:px-6 py-3.5 sm:py-4 rounded-2xl bg-[#25D366] text-white font-bold text-sm transition-all duration-300 hover:bg-[#20bd5a] hover:shadow-lg hover:shadow-[#25D366]/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#25D366] focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900"
              >
                <WhatsApp class="w-4 h-4 shrink-0" />
                <span class="sm:hidden">Escríbenos</span>
                <span class="hidden sm:inline">Iniciar conversación</span>
                <Arrow
                  to="right"
                  class="hidden sm:block w-4 h-4 opacity-80 transition-transform duration-300 group-hover/btn:translate-x-1"
                />
              </a>

              <p
                class="mt-3 sm:mt-4 text-center text-[11px] sm:text-xs text-zinc-500"
              >
                <span class="sm:hidden">Lun–Vie · 8am–6pm</span>
                <span class="hidden sm:inline"
                  >Lun – Vie · 8:00 a.m. – 6:00 p.m.</span
                >
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes banner-reveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .banner-reveal {
    animation: banner-reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .banner-reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
