---
import { WHATSAPP_URL } from "../data/products";

interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = "¿Listo para empezar tu proyecto?",
  subtext = "Cuéntanos tu idea y te ayudamos a hacerla realidad. Respuesta rápida, asesoría personalizada.",
} = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-28 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="relative rounded-[2.5rem] sm:rounded-[3rem] overflow-hidden bg-zinc-900 shadow-2xl shadow-zinc-900/20"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-brand-500/10 via-transparent to-amber-500/5 pointer-events-none"
      >
      </div>

      <div
        class="absolute top-0 left-[5%] right-[5%] h-px bg-gradient-to-r from-transparent via-brand-500/50 to-transparent"
      >
      </div>

      <div class="relative z-10 grid lg:grid-cols-2">
        <!-- Left: copy -->
        <div
          class="p-10 sm:p-14 lg:p-16 xl:p-20 flex flex-col justify-center lg:border-r lg:border-white/10"
        >
          <div class="flex items-center gap-3 mb-6">
            <span class="block w-6 h-px bg-brand-500"></span>
            <span
              class="inline-flex items-center px-3 py-1 rounded-full bg-brand-500/15 border border-brand-500/30 text-brand-500 text-[11px] font-bold uppercase tracking-widest"
            >
              Hablemos
            </span>
          </div>

          <h2
            class="text-3xl sm:text-4xl xl:text-[2.75rem] font-extrabold text-white tracking-tight leading-[1.1] mb-5"
          >
            {headline}
          </h2>

          <p class="text-base sm:text-lg text-zinc-300 leading-relaxed max-w-[36ch]">
            {subtext}
          </p>
        </div>

        <!-- Right: WhatsApp CTA -->
        <div class="p-10 sm:p-14 lg:p-16 xl:p-20 flex flex-col justify-center">
          <div class="flex items-center gap-2 mb-3">
            <span class="block w-1.5 h-1.5 rounded-full bg-[#25D366]"></span>
            <span
              class="text-[11px] font-bold text-[#25D366] uppercase tracking-widest"
            >
              WhatsApp
            </span>
          </div>

          <p
            class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-none mb-8"
          >
            +57 321 642 6377
          </p>

          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2.5 w-fit px-7 py-4 rounded-xl bg-[#25D366] text-white font-bold text-sm transition-all duration-200 hover:bg-[#20bd5a] hover:shadow-lg hover:shadow-[#25D366]/30"
          >
            <svg
              class="w-4 h-4 shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            Iniciar conversación
            <svg
              class="w-3.5 h-3.5 opacity-80 transition-transform duration-200 group-hover:translate-x-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
