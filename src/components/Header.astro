---
import { products } from "../data/products";

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Productos", dropdown: true },
];

const dropdownItems = products.map((p) => ({
  label: p.navLabel,
  href: `/productos/${p.slug}`,
}));
---

<header
  class="fixed w-full bg-[#212120]/95 backdrop-blur-md top-0 h-16 z-50 transition-all duration-500 border-b border-white/5"
  id="header"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-[1fr_auto] md:grid-cols-[1fr_auto_1fr] items-center h-16">
      <!-- Logo -->
      <div class="flex items-center justify-self-start">
        <a href="/" class="flex items-center gap-3 group">
          <div class="relative">
            <img
              class="h-12 w-auto transition-all duration-500 group-hover:scale-105 group-hover:brightness-110"
              src="/public/HorizontalWhiteLogo.png"
              alt="Estilo Gráfico"
            />
            <div
              class="absolute -inset-2 bg-brand-500/10 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm"
            >
            </div>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center justify-center gap-1 md:col-start-2">
        {
          navItems.map((item) => (
            item.dropdown ? (
              <div class="relative group">
                <button
                  type="button"
                  class="relative px-4 py-2 text-white/80 hover:text-white font-medium text-sm transition-all duration-300 inline-flex items-center gap-1.5 cursor-pointer"
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  <span class="relative z-10 uppercase tracking-wider text-xs">{item.label}</span>
                  <svg class="w-3 h-3 text-brand-500 transition-transform duration-300 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                  </svg>
                  <div class="absolute inset-0 bg-white/5 rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-300 scale-95 group-hover:scale-100" />
                  <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-brand-500 to-brand-600 transition-all duration-300 group-hover:w-6 rounded-full" />
                </button>

                <!-- Dropdown -->
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                  <div class="bg-[#212120] border border-white/10 rounded-2xl p-2 shadow-2xl shadow-black/40 min-w-[280px]">
                    {dropdownItems.map((di) => (
                      <a href={di.href} class="block px-4 py-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl text-sm transition-all duration-200 whitespace-nowrap">
                        {di.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="relative px-4 py-2 text-white/80 hover:text-white font-medium text-sm transition-all duration-300 group"
              >
                <span class="relative z-10 uppercase tracking-wider text-xs">
                  {item.label}
                </span>
                <div class="absolute inset-0 bg-white/5 rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-300 scale-95 group-hover:scale-100" />
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-brand-500 to-brand-600 transition-all duration-300 group-hover:w-6 rounded-full" />
              </a>
            )
          ))
        }
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center justify-self-end md:col-start-3">
        <a
          href="https://wa.me/573216426377"
          target="_blank"
          rel="noopener noreferrer"
          class="relative inline-flex items-center justify-center px-7 py-3 overflow-hidden rounded-full font-bold text-sm text-zinc-900 group"
        >
          <div
            class="absolute inset-0 bg-gradient-to-r from-brand-500 to-brand-600 transition-transform duration-500 group-hover:scale-105"
          >
          </div>
          <div
            class="absolute inset-0 bg-gradient-to-r from-brand-400 to-brand-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
          <span class="relative z-10 flex items-center gap-2">
            Contáctanos
            <svg
              class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center justify-self-end md:hidden">
        <button
          type="button"
          class="inline-flex items-center justify-center p-2.5 rounded-xl text-white/70 hover:text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-500 transition-all duration-300"
          aria-expanded="false"
          id="mobile-menu-button"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg
            class="block h-5 w-5 transition-transform duration-300"
            id="icon-hamburger"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- Close icon -->
          <svg
            class="hidden h-5 w-5 transition-transform duration-300"
            id="icon-close"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  id="mobile-overlay"
>
</div>

<!-- Mobile Menu Panel -->
<div
  class="fixed top-0 right-0 bottom-0 w-[80%] max-w-sm bg-[#1a1a19] z-50 transform translate-x-full transition-transform duration-500 ease-out md:hidden"
  id="mobile-menu"
>
  <!-- Close button inside panel -->
  <div class="flex justify-end p-4">
    <button
      type="button"
      class="p-2 rounded-xl text-white/60 hover:text-white hover:bg-white/10 transition-all duration-300"
      id="mobile-close-button"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
        </svg>
    </button>
  </div>

  <div class="flex flex-col h-[calc(100%-80px)] px-6 pb-6">
    <!-- Nav Links -->
    <nav class="flex flex-col gap-1">
      {
        navItems.map((item) => (
          item.dropdown ? (
            <div>
              <span class="flex items-center justify-between gap-4 px-4 py-4 text-white font-medium">
                <span class="text-lg tracking-wide">{item.label}</span>
                <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
              <div class="ml-4 pl-4 border-l border-white/10 space-y-1 mt-1">
                {dropdownItems.map((di) => (
                  <a href={di.href} class="mobile-nav-link block px-4 py-3 text-white/60 hover:text-white/90 hover:bg-white/5 rounded-xl text-sm transition-all duration-200">
                    {di.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="mobile-nav-link flex items-center gap-4 px-4 py-4 text-white hover:text-brand-400 hover:bg-white/5 rounded-xl font-medium transition-all duration-300"
            >
              <span class="text-lg tracking-wide">{item.label}</span>
            </a>
          )
        ))
      }
    </nav>

    <!-- Contact Info -->
    <div class="mt-auto pt-6 border-t border-white/10">
      <p class="text-zinc-500 text-sm mb-2">¿Prefieres llamarnos?</p>
      <a
        href="tel:+573216426377"
        class="text-white hover:text-brand-400 transition-colors font-medium"
      >
        +57 321 642 6377
      </a>
    </div>
  </div>
</div>

<script>
  let isMenuOpen = false;

  function closeMenu() {
    isMenuOpen = false;
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileOverlay = document.getElementById("mobile-overlay");
    const menuButton = document.getElementById("mobile-menu-button");

    mobileMenu?.classList.add("translate-x-full");
    mobileMenu?.classList.remove("translate-x-0");
    mobileOverlay?.classList.add("opacity-0", "pointer-events-none");
    mobileOverlay?.classList.remove("opacity-100");
    menuButton?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  function openMenu() {
    isMenuOpen = true;
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileOverlay = document.getElementById("mobile-overlay");
    const menuButton = document.getElementById("mobile-menu-button");

    mobileMenu?.classList.remove("translate-x-full");
    mobileMenu?.classList.add("translate-x-0");
    mobileOverlay?.classList.remove("opacity-0", "pointer-events-none");
    mobileOverlay?.classList.add("opacity-100");
    menuButton?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");

    if (window.pageYOffset > 50) {
      header?.classList.add("shadow-2xl", "shadow-black/20");
    } else {
      header?.classList.remove("shadow-2xl", "shadow-black/20");
    }
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    if (target.closest("#mobile-menu-button")) {
      if (isMenuOpen) closeMenu();
      else openMenu();
      return;
    }

    if (
      target.closest("#mobile-close-button") ||
      target.closest("#mobile-overlay") ||
      target.closest(".mobile-nav-link")
    ) {
      closeMenu();
    }
  });

  document.addEventListener("astro:page-load", closeMenu);
</script>
