---
import { products, WHATSAPP_URL } from "../data/products";
import Arrow from "./icons/Arrow.astro";
import Chevron from "./icons/Chevron.astro";
import Close from "./icons/Close.astro";
import Menu from "./icons/Menu.astro";
import WhatsApp from "./icons/WhatsApp.astro";
import { SITE } from "../data/site";

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Productos", dropdown: true },
];

const dropdownItems = products.map((p) => ({
  label: p.navLabel,
  href: `/productos/${p.slug}`,
}));
const externalLinkProps = {
  target: "_blank",
  rel: "noopener noreferrer",
};
---

<header
  class="fixed w-full bg-[#212120]/95 backdrop-blur-md top-0 h-16 z-40 transition-all duration-500 border-b border-white/5"
  id="header"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="grid grid-cols-[1fr_auto] md:grid-cols-[1fr_auto_1fr] items-center h-16"
    >
      <!-- Logo -->
      <div class="flex items-center justify-self-start">
        <a href="/" class="flex items-center gap-3 group">
          <div class="relative">
            <img
              class="h-12 w-auto transition-all duration-500 group-hover:scale-105 group-hover:brightness-110"
              src="/BottomlessWhiteLogo.png"
              alt="Estilo Gráfico"
            />
            <div
              class="absolute -inset-2 bg-brand-500/10 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm"
            >
            </div>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav
        class="hidden md:flex items-center justify-center gap-1 md:col-start-2"
      >
        {
          navItems.map((item) =>
            item.dropdown ? (
              <div class="relative group">
                <button
                  type="button"
                  class="relative px-4 py-2 text-white/80 hover:text-white font-medium text-sm transition-all duration-300 inline-flex items-center gap-1.5 cursor-pointer"
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  <span class="relative z-10 uppercase tracking-wider text-xs">
                    {item.label}
                  </span>
                  <span class="inline-flex transition-transform duration-300 group-hover:rotate-180">
                    <Chevron to="down" class="w-3 h-3 text-brand-500" />
                  </span>
                  <div class="absolute inset-0 bg-white/5 rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-300 scale-95 group-hover:scale-100" />
                  <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-linear-to-r from-brand-500 to-brand-600 transition-all duration-300 group-hover:w-6 rounded-full" />
                </button>

                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                  <div class="bg-[#212120] border border-white/10 rounded-2xl p-2 shadow-2xl shadow-black/40 min-w-[280px]">
                    {dropdownItems.map((di) => (
                      <a
                        href={di.href}
                        class="block px-4 py-3 text-white/70 hover:text-white hover:bg-white/5 rounded-xl text-sm transition-all duration-200 whitespace-nowrap"
                      >
                        {di.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class="relative px-4 py-2 text-white/80 hover:text-white font-medium text-sm transition-all duration-300 group"
              >
                <span class="relative z-10 uppercase tracking-wider text-xs">
                  {item.label}
                </span>
                <div class="absolute inset-0 bg-white/5 rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-300 scale-95 group-hover:scale-100" />
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-linear-to-r from-brand-500 to-brand-600 transition-all duration-300 group-hover:w-6 rounded-full" />
              </a>
            ),
          )
        }
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center justify-self-end md:col-start-3">
        <div class="flex items-center mr-4">
          <a
            href={SITE.social.facebook}
            {...externalLinkProps}
            class="group p-3 hover:border-brand-500/30 transition-all duration-300"
          >
            <span class="sr-only">Facebook</span>
            <svg
              fill="currentColor"
              aria-hidden="true"
              class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
              viewBox="0 0 24 24"
              ><path
                fill-rule="evenodd"
                d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12"
                clip-rule="evenodd"></path></svg
            >
          </a>
          <a
            href={SITE.social.instagram}
            {...externalLinkProps}
            class="group p-3 hover:border-brand-500/30 transition-all duration-300"
          >
            <span class="sr-only">Instagram</span>
            <svg
              fill="currentColor"
              aria-hidden="true"
              class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
              viewBox="0 0 24 24"
              ><path
                fill-rule="evenodd"
                d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.9 4.9 0 0 1 1.772 1.153 4.9 4.9 0 0 1 1.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.9 4.9 0 0 1-1.153 1.772 4.9 4.9 0 0 1-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.9 4.9 0 0 1-1.772-1.153 4.9 4.9 0 0 1-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.9 4.9 0 0 1 1.153-1.772A4.9 4.9 0 0 1 5.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748s-.566.683-.748 1.15c-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748s.566-.683.748-1.15c.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.1 3.1 0 0 0-.748-1.15 3.1 3.1 0 0 0-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058M12 6.865a5.135 5.135 0 1 1 0 10.27 5.135 5.135 0 0 1 0-10.27m0 1.802a3.333 3.333 0 1 0 0 6.666 3.333 3.333 0 0 0 0-6.666m5.338-3.205a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4"
                clip-rule="evenodd"></path></svg
            >
          </a>
        </div>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="relative inline-flex items-center justify-center px-7 py-3 overflow-hidden rounded-full font-bold text-sm text-zinc-900 group"
        >
          <div
            class="absolute inset-0 bg-linear-to-r from-brand-500 to-brand-600 transition-transform duration-500 group-hover:scale-105"
          >
          </div>
          <div
            class="absolute inset-0 bg-linear-to-r from-brand-400 to-brand-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
          <span class="relative z-10 flex items-center gap-2">
            Contáctanos
            <span
              class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5"
            >
              <Arrow to="right" class="w-4 h-4" />
            </span>
          </span>
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center justify-self-end md:hidden">
        <button
          type="button"
          class="inline-flex items-center justify-center p-2.5 rounded-xl text-white/70 hover:text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-500 transition-all duration-300"
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="mobile-menu-button"
        >
          <span class="sr-only">Abrir menú principal</span>
          <Menu
            class="block h-5 w-5 transition-transform duration-300"
            id="icon-hamburger"
          />
          <Close
            class="hidden h-5 w-5 transition-transform duration-300"
            id="icon-close"
          />
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay (above header) -->
<div
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  id="mobile-overlay"
  aria-hidden="true"
>
</div>

<!-- Mobile Menu Panel -->
<div
  class="fixed top-0 right-0 bottom-0 w-[80%] max-w-sm bg-[#1a1a19] z-60 transform translate-x-full transition-transform duration-500 ease-out md:hidden"
  id="mobile-menu"
  aria-hidden="true"
>
  <div
    class="flex items-center justify-between gap-4 p-4 border-b border-white/10"
  >
    <a href="/" class="mobile-nav-link shrink-0">
      <img
        src="/BottomlessWhiteLogo.png"
        alt="Estilo Gráfico"
        class="h-10 w-auto"
      />
    </a>
    <button
      type="button"
      class="p-2 rounded-xl text-white/60 hover:text-white hover:bg-white/10 transition-all duration-300 shrink-0"
      id="mobile-close-button"
      aria-label="Cerrar menú"
    >
      <Close class="w-6 h-6" />
    </button>
  </div>

  <div class="flex flex-col h-[calc(100%-73px)] px-6 pb-6 overflow-y-auto">
    <nav class="flex flex-col gap-1">
      {
        navItems.map((item) =>
          item.dropdown ? (
            <div class="mobile-products-group">
              <button
                type="button"
                id="mobile-products-toggle"
                class="w-full flex items-center justify-between gap-4 px-4 py-4 text-white font-medium hover:bg-white/5 rounded-xl transition-all duration-300"
                aria-expanded="true"
                aria-controls="mobile-products-panel"
              >
                <span class="text-lg tracking-wide">{item.label}</span>
                <span
                  id="mobile-products-chevron"
                  class="inline-flex shrink-0 transition-transform duration-300 rotate-180"
                >
                  <Chevron to="down" class="w-4 h-4 text-brand-500" />
                </span>
              </button>

              <div
                id="mobile-products-panel"
                class="grid grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out"
                aria-hidden="false"
              >
                <div class="overflow-hidden">
                  <div class="ml-4 pl-4 border-l border-white/10 space-y-1 pb-2 pt-1">
                    {dropdownItems.map((di) => (
                      <a
                        href={di.href}
                        class="mobile-nav-link block px-4 py-3 text-white/60 hover:text-white/90 hover:bg-white/5 rounded-xl text-sm transition-all duration-200"
                      >
                        {di.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="mobile-nav-link flex items-center gap-4 px-4 py-4 text-white hover:text-brand-400 hover:bg-white/5 rounded-xl font-medium transition-all duration-300"
            >
              <span class="text-lg tracking-wide">{item.label}</span>
            </a>
          ),
        )
      }
    </nav>

    <div class="mt-auto pt-6 border-t border-white/10 space-y-4">
      <!-- Social Icons -->
      <div class="flex items-center gap-3">
        <a
          href={SITE.social.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-nav-link p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
          aria-label="Facebook"
        >
          <svg
            fill="currentColor"
            aria-hidden="true"
            class="h-5 w-5 text-zinc-400 hover:text-brand-500 transition-colors"
            viewBox="0 0 24 24"
            ><path
              fill-rule="evenodd"
              d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12"
              clip-rule="evenodd"></path></svg
          >
        </a>
        <a
          href={SITE.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-nav-link p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
          aria-label="Instagram"
        >
          <svg
            fill="currentColor"
            aria-hidden="true"
            class="h-5 w-5 text-zinc-400 hover:text-brand-500 transition-colors"
            viewBox="0 0 24 24"
            ><path
              fill-rule="evenodd"
              d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.9 4.9 0 0 1 1.772 1.153 4.9 4.9 0 0 1 1.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.9 4.9 0 0 1-1.153 1.772 4.9 4.9 0 0 1-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.9 4.9 0 0 1-1.772-1.153 4.9 4.9 0 0 1-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.9 4.9 0 0 1 1.153-1.772A4.9 4.9 0 0 1 5.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748s-.566.683-.748 1.15c-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748s.566-.683.748-1.15c.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.1 3.1 0 0 0-.748-1.15 3.1 3.1 0 0 0-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058M12 6.865a5.135 5.135 0 1 1 0 10.27 5.135 5.135 0 0 1 0-10.27m0 1.802a3.333 3.333 0 1 0 0 6.666 3.333 3.333 0 0 0 0-6.666m5.338-3.205a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4"
              clip-rule="evenodd"></path></svg
          >
        </a>
      </div>

      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl bg-green-500/10 border border-green-500/20 hover:bg-green-500/15 hover:border-green-500/30 transition-all duration-300"
      >
        <WhatsApp class="w-5 h-5 text-green-500 shrink-0" />
        <span class="text-white font-medium">Escríbenos por WhatsApp</span>
      </a>
    </div>
  </div>
</div>

<script>
  let isMenuOpen = false;

  function setMenuIcons(open: boolean) {
    const hamburger = document.getElementById("icon-hamburger");
    const close = document.getElementById("icon-close");

    hamburger?.classList.toggle("hidden", open);
    hamburger?.classList.toggle("block", !open);
    close?.classList.toggle("hidden", !open);
    close?.classList.toggle("block", open);
  }

  function closeProductsDropdown() {
    const panel = document.getElementById("mobile-products-panel");
    const toggle = document.getElementById("mobile-products-toggle");
    const chevron = document.getElementById("mobile-products-chevron");

    panel?.classList.remove("grid-rows-[1fr]");
    panel?.classList.add("grid-rows-[0fr]");
    panel?.setAttribute("aria-hidden", "true");
    toggle?.setAttribute("aria-expanded", "false");
    chevron?.classList.remove("rotate-180");
  }

  function openProductsDropdown() {
    const panel = document.getElementById("mobile-products-panel");
    const toggle = document.getElementById("mobile-products-toggle");
    const chevron = document.getElementById("mobile-products-chevron");

    panel?.classList.remove("grid-rows-[0fr]");
    panel?.classList.add("grid-rows-[1fr]");
    panel?.setAttribute("aria-hidden", "false");
    toggle?.setAttribute("aria-expanded", "true");
    chevron?.classList.add("rotate-180");
  }

  function toggleProductsDropdown() {
    const toggle = document.getElementById("mobile-products-toggle");
    const isOpen = toggle?.getAttribute("aria-expanded") === "true";

    if (isOpen) {
      closeProductsDropdown();
      return;
    }

    openProductsDropdown();
  }

  function closeMenu() {
    isMenuOpen = false;
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileOverlay = document.getElementById("mobile-overlay");
    const menuButton = document.getElementById("mobile-menu-button");

    mobileMenu?.classList.add("translate-x-full");
    mobileMenu?.classList.remove("translate-x-0");
    mobileMenu?.setAttribute("aria-hidden", "true");
    mobileOverlay?.classList.add("opacity-0", "pointer-events-none");
    mobileOverlay?.classList.remove("opacity-100");
    mobileOverlay?.setAttribute("aria-hidden", "true");
    menuButton?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    setMenuIcons(false);
  }

  function openMenu() {
    isMenuOpen = true;
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileOverlay = document.getElementById("mobile-overlay");
    const menuButton = document.getElementById("mobile-menu-button");

    mobileMenu?.classList.remove("translate-x-full");
    mobileMenu?.classList.add("translate-x-0");
    mobileMenu?.setAttribute("aria-hidden", "false");
    mobileOverlay?.classList.remove("opacity-0", "pointer-events-none");
    mobileOverlay?.classList.add("opacity-100");
    mobileOverlay?.setAttribute("aria-hidden", "false");
    menuButton?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
    setMenuIcons(true);
  }

  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");

    if (window.pageYOffset > 50) {
      header?.classList.add("shadow-2xl", "shadow-black/20");
    } else {
      header?.classList.remove("shadow-2xl", "shadow-black/20");
    }
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    if (target.closest("#mobile-menu-button")) {
      if (isMenuOpen) closeMenu();
      else openMenu();
      return;
    }

    if (target.closest("#mobile-products-toggle")) {
      toggleProductsDropdown();
      return;
    }

    if (
      target.closest("#mobile-close-button") ||
      target.closest("#mobile-overlay") ||
      target.closest(".mobile-nav-link")
    ) {
      closeMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && isMenuOpen) {
      closeMenu();
    }
  });

  document.addEventListener("astro:page-load", closeMenu);
</script>
