---
import { SITE } from "../data/site";

const year = new Date().getFullYear();
const externalLinkProps = {
  target: "_blank",
  rel: "noopener noreferrer",
};
---

<footer id="contacto" class="relative bg-[#212120] overflow-hidden">
  <!-- Top decorative border -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-500/30 to-transparent"
  >
  </div>

  <!-- Background accents -->
  <div
    class="absolute top-0 right-0 w-96 h-96 bg-brand-500/5 rounded-full blur-[100px]"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-64 h-64 bg-amber-500/5 rounded-full blur-[80px]"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main Footer Content -->
    <div class="pt-20 pb-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <!-- Brand Column -->
        <div class="lg:col-span-5">
          <a href="/" class="inline-block mb-2 group">
            <img
              src="/HorizontalWhiteLogo.png"
              alt="Estilo Gráfico Logo"
              class="h-26 w-40 transition-all duration-300 group-hover:brightness-110"
            />
          </a>
          <p class="text-zinc-400 max-w-sm mb-8 leading-relaxed text-lg">
            Soluciones de impresión y diseño profesional de alta calidad.
            Transformamos tus ideas en realidad con tecnología de vanguardia.
          </p>

          <!-- Social Links -->
          <div class="flex gap-3">
            <a
              href={SITE.social.facebook}
              {...externalLinkProps}
              class="group p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
            >
              <span class="sr-only">Facebook</span>
              <svg
                fill="currentColor"
                aria-hidden="true"
                class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
                viewBox="0 0 24 24"
                ><path
                  fill-rule="evenodd"
                  d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12"
                  clip-rule="evenodd"></path></svg
              >
            </a>
            <a
              href={SITE.social.instagram}
              {...externalLinkProps}
              class="group p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
            >
              <span class="sr-only">Instagram</span>
              <svg
                fill="currentColor"
                aria-hidden="true"
                class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
                viewBox="0 0 24 24"
                ><path
                  fill-rule="evenodd"
                  d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.9 4.9 0 0 1 1.772 1.153 4.9 4.9 0 0 1 1.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.9 4.9 0 0 1-1.153 1.772 4.9 4.9 0 0 1-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.9 4.9 0 0 1-1.772-1.153 4.9 4.9 0 0 1-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.9 4.9 0 0 1 1.153-1.772A4.9 4.9 0 0 1 5.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748s-.566.683-.748 1.15c-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748s.566-.683.748-1.15c.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.1 3.1 0 0 0-.748-1.15 3.1 3.1 0 0 0-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058M12 6.865a5.135 5.135 0 1 1 0 10.27 5.135 5.135 0 0 1 0-10.27m0 1.802a3.333 3.333 0 1 0 0 6.666 3.333 3.333 0 0 0 0-6.666m5.338-3.205a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4"
                  clip-rule="evenodd"></path></svg
              >
            </a>
            <a
              href={SITE.whatsapp}
              {...externalLinkProps}
              class="group p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
            >
              <span class="sr-only">WhatsApp</span>
              <svg
                class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="lg:col-span-2 lg:col-start-7">
          <h3
            class="text-xs font-semibold text-white tracking-wider uppercase mb-6 flex items-center gap-2"
          >
            <span class="w-8 h-px bg-brand-500"></span>
            Enlaces Rápidos
          </h3>
          <ul class="space-y-4">
            <li>
              <a
                href="/"
                class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-colors duration-300"
              >
                <span
                  class="w-0 group-hover:w-2 h-px bg-brand-500 transition-all duration-300"
                ></span>
                Inicio
              </a>
            </li>
            <li>
              <a
                href="/nosotros"
                class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-colors duration-300"
              >
                <span
                  class="w-0 group-hover:w-2 h-px bg-brand-500 transition-all duration-300"
                ></span>
                Nosotros
              </a>
            </li>
            <li>
              <a
                href="#productos"
                class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-colors duration-300"
              >
                <span
                  class="w-0 group-hover:w-2 h-px bg-brand-500 transition-all duration-300"
                ></span>
                Productos
              </a>
            </li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="lg:col-span-3">
          <h3
            class="text-xs font-semibold text-white tracking-wider uppercase mb-6 flex items-center gap-2"
          >
            <span class="w-8 h-px bg-brand-500"></span>
            Contacto
          </h3>
          <ul class="space-y-5">
            <li class="flex items-center gap-4">
              <div
                class="p-2 bg-brand-500/10 rounded-lg border border-brand-500/20"
              >
                <svg
                  class="h-5 w-5 text-brand-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </div>
              <div>
                <a
                  href={SITE.whatsapp}
                  {...externalLinkProps}
                  class="text-zinc-300 hover:text-white transition-colors font-medium"
                >
                  {SITE.phone}
                </a>
              </div>
            </li>
            <li class="flex items-center gap-4">
              <div
                class="p-2 bg-brand-500/10 rounded-lg border border-brand-500/20"
              >
                <svg
                  class="h-5 w-5 text-brand-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <a
                  href={`mailto:${SITE.email}`}
                  class="text-zinc-300 hover:text-white transition-colors font-medium"
                >
                  {SITE.email}
                </a>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="py-8 border-t border-white/5">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-zinc-500 text-sm">
          &copy; {year} Estilo Gráfico. Todos los derechos reservados.
        </p>
        <!-- terms and privacy (Hidden temporarily)-->
        <div class="flex gap-6 hidden">
          <a
            href="#"
            class="text-zinc-500 hover:text-zinc-300 text-sm transition-colors"
            >Términos</a
          >
          <a
            href="#"
            class="text-zinc-500 hover:text-zinc-300 text-sm transition-colors"
            >Privacidad</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
