---
const year = new Date().getFullYear();
---

<footer class="relative bg-[#212120] overflow-hidden">
  <!-- Top decorative border -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-500/30 to-transparent"
  >
  </div>

  <!-- Background accents -->
  <div
    class="absolute top-0 right-0 w-96 h-96 bg-brand-500/5 rounded-full blur-[100px]"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-64 h-64 bg-amber-500/5 rounded-full blur-[80px]"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main Footer Content -->
    <div class="pt-20 pb-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <!-- Brand Column -->
        <div class="lg:col-span-5">
          <a href="/" class="inline-block mb-6 group">
            <img
              src="/HorizontalWhiteLogo.png"
              alt="Estilo Gráfico Logo"
              class="h-16 w-auto transition-all duration-300 group-hover:brightness-110"
            />
          </a>
          <p class="text-zinc-400 max-w-sm mb-8 leading-relaxed text-lg">
            Soluciones de impresión y diseño profesional de alta calidad.
            Transformamos tus ideas en realidad con tecnología de vanguardia.
          </p>

          <!-- Social Links -->
          <div class="flex gap-3">
            <a
              href="#"
              class="group p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
            >
              <span class="sr-only">Facebook</span>
              <svg
                class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
            <a
              href="#"
              class="group p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
            >
              <span class="sr-only">Instagram</span>
              <svg
                class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
            <a
              href="#"
              class="group p-3 bg-white/5 rounded-xl border border-white/10 hover:bg-brand-500/10 hover:border-brand-500/30 transition-all duration-300"
            >
              <span class="sr-only">LinkedIn</span>
              <svg
                class="h-5 w-5 text-zinc-400 group-hover:text-brand-500 transition-colors"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="lg:col-span-2 lg:col-start-7">
          <h3
            class="text-xs font-semibold text-white tracking-wider uppercase mb-6 flex items-center gap-2"
          >
            Enlaces Rápidos
          </h3>
          <ul class="space-y-4">
            <li>
              <a
                href="/"
                class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-colors duration-300"
              >
                <span
                  class="w-0 group-hover:w-2 h-px bg-brand-500 transition-all duration-300"
                ></span>
                Inicio
              </a>
            </li>
            <li>
              <a
                href="/nosotros"
                class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-colors duration-300"
              >
                <span
                  class="w-0 group-hover:w-2 h-px bg-brand-500 transition-all duration-300"
                ></span>
                Nosotros
              </a>
            </li>
            <li>
              <a
                href="/#productos"
                class="group flex items-center gap-2 text-zinc-400 hover:text-white transition-colors duration-300"
              >
                <span
                  class="w-0 group-hover:w-2 h-px bg-brand-500 transition-all duration-300"
                ></span>
                Productos
              </a>
            </li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="lg:col-span-3">
          <h3
            class="text-xs font-semibold text-white tracking-wider uppercase mb-6 flex items-center gap-2"
          >
            Contacto
          </h3>
          <ul class="space-y-5">
            <li class="flex items-center gap-4">
              <div
                class="p-2 bg-brand-500/10 rounded-lg border border-brand-500/20"
              >
                <svg
                  class="h-5 w-5 text-brand-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </div>
              <div>
                <a
                  href="https://wa.me/573216426377"
                  class="text-zinc-300 hover:text-white transition-colors font-medium"
                >
                  +57 321 642 6377
                </a>
              </div>
            </li>
            <li class="flex items-center gap-4">
              <div
                class="p-2 bg-brand-500/10 rounded-lg border border-brand-500/20"
              >
                <svg
                  class="h-5 w-5 text-brand-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <a
                  href="mailto:estilograficog@gmail.com"
                  class="text-zinc-300 hover:text-white transition-colors font-medium"
                >
                  estilograficog@gmail.com
                </a>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="py-8 border-t border-white/5">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-zinc-500 text-sm">
          &copy; {year} Estilo Gráfico. Todos los derechos reservados.
        </p>
        <div class="flex gap-6">
          <a
            href="#"
            class="text-zinc-500 hover:text-zinc-300 text-sm transition-colors"
            >Términos</a
          >
          <a
            href="#"
            class="text-zinc-500 hover:text-zinc-300 text-sm transition-colors"
            >Privacidad</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>
