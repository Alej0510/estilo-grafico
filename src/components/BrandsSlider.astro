---
import { Image } from "astro:assets";
import Edding from "../assets/Edding.png";
import Enviaseo from "../assets/Enviaseo.png";
import Madecentro from "../assets/madecentro.jpg";
import Pool from "../assets/Pool.png";

const brands = [
  { name: "Edding", logo: Edding, height: "max-h-12" },
  { name: "Enviaseo", logo: Enviaseo, height: "max-h-20" },
  { name: "Madecentro", logo: Madecentro, height: "max-h-12" },
  { name: "Pool", logo: Pool, height: "max-h-20" },
];
---

<section class="py-10 bg-white/90 backdrop-blur-sm border-y border-white/10">
  <div class="relative overflow-hidden" id="brands-marquee-viewport">
    <div
      class="absolute left-0 top-0 bottom-0 w-24 bg-linear-to-r from-white/90 to-transparent z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute right-0 top-0 bottom-0 w-24 bg-linear-to-l from-white/90 to-transparent z-10 pointer-events-none"
    >
    </div>

    <div class="marquee-track flex w-max" id="brands-marquee-track">
      <div class="marquee-segment flex items-center gap-16 shrink-0 pr-16">
        {
          brands.map((brand) => (
            <div class="flex items-center justify-center w-40 h-20 shrink-0">
              <Image
                src={brand.logo}
                alt={brand.name}
                class={`${brand.height} w-auto object-contain opacity-40 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-500`}
                loading="eager"
              />
            </div>
          ))
        }
      </div>
      <div
        class="marquee-segment flex items-center gap-16 shrink-0 pr-16"
        aria-hidden="true"
      >
        {
          brands.map((brand) => (
            <div class="flex items-center justify-center w-40 h-20 shrink-0">
              <Image
                src={brand.logo}
                alt=""
                class={`${brand.height} w-auto object-contain opacity-40 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-500`}
                loading="eager"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function setupBrandsMarquee() {
    const viewport = document.getElementById("brands-marquee-viewport");
    const track = document.getElementById("brands-marquee-track");
    if (!viewport || !track) return;

    const segments = () => track.querySelectorAll(".marquee-segment");

    const fillTrack = () => {
      const list = segments();
      if (list.length < 2) return;

      const template = list[1];
      const viewportWidth = viewport.clientWidth;
      const shift = (list[1] as HTMLElement).offsetLeft;
      const minWidth = viewportWidth + shift;

      while (track.scrollWidth < minWidth) {
        const clone = template.cloneNode(true);
        if (clone instanceof HTMLElement) {
          clone.setAttribute("aria-hidden", "true");
          track.appendChild(clone);
        }
      }
    };

    const updateShift = () => {
      fillTrack();

      const list = segments();
      if (list.length < 2) return;

      const shift = (list[1] as HTMLElement).offsetLeft;
      if (shift <= 0) return;

      track.style.setProperty("--marquee-shift", `${shift}px`);
      track.classList.add("marquee-ready");
    };

    const waitForImages = () => {
      const images = track.querySelectorAll("img");
      const pending = [...images].filter((img) => !img.complete);

      if (pending.length === 0) {
        requestAnimationFrame(updateShift);
        return;
      }

      let loaded = 0;
      const onDone = () => {
        loaded += 1;
        if (loaded === pending.length) {
          requestAnimationFrame(updateShift);
        }
      };

      pending.forEach((img) => {
        img.addEventListener("load", onDone, { once: true });
        img.addEventListener("error", onDone, { once: true });
      });
    };

    waitForImages();

    const observer = new ResizeObserver(() => {
      requestAnimationFrame(updateShift);
    });
    observer.observe(viewport);

    window.addEventListener("resize", updateShift);
  }

  setupBrandsMarquee();
  document.addEventListener("astro:page-load", setupBrandsMarquee);
</script>

<style>
  .marquee-track {
    --marquee-shift: 0px;
    --marquee-duration: 22s;
    will-change: transform;
  }

  .marquee-track.marquee-ready {
    animation: marquee-scroll var(--marquee-duration) linear infinite;
  }

  .marquee-track.marquee-ready:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(calc(-1 * var(--marquee-shift)), 0, 0);
    }
  }
</style>
