---
import { Image } from "astro:assets";
import Edding from "../assets/Edding.png";
import Enviaseo from "../assets/Enviaseo.png";
import Madecentro from "../assets/madecentro.jpg";
import Pool from "../assets/Pool.png";

const brands = [
  { name: "Edding", logo: Edding },
  { name: "Enviaseo", logo: Enviaseo },
  { name: "Madecentro", logo: Madecentro },
  { name: "Pool", logo: Pool },
];
---

<section
  class="border-y-[0.5px] border-white/25 bg-white/12 py-10 backdrop-blur-[50px]"
>
  <div
    class="relative overflow-hidden mask-[linear-gradient(to_right,transparent,black_6rem,black_calc(100%-6rem),transparent)]"
    id="brands-marquee-viewport"
  >
    <div
      class="flex w-max will-change-transform [--marquee-shift:0px] hover:[animation-play-state:paused]"
      id="brands-marquee-track"
    >
      <div class="marquee-segment flex shrink-0 items-center gap-16 pr-16">
        {
          brands.map((brand) => (
            <Image
              src={brand.logo}
              alt={brand.name}
              class="h-12 w-auto max-w-40 shrink-0 object-contain opacity-95 grayscale transition-all duration-500 hover:opacity-100 hover:grayscale-0"
              loading="eager"
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function setupBrandsMarquee() {
    const viewport = document.getElementById("brands-marquee-viewport");
    const track = document.getElementById("brands-marquee-track");
    if (!viewport || !track) return;

    const segments = () => track.querySelectorAll(".marquee-segment");

    const ensureLoopSegment = () => {
      const list = segments();
      if (list.length !== 1) return;

      const clone = list[0].cloneNode(true);
      if (!(clone instanceof HTMLElement)) return;

      clone.setAttribute("aria-hidden", "true");
      clone
        .querySelectorAll("img")
        .forEach((img) => img.setAttribute("alt", ""));
      track.appendChild(clone);
    };

    const fillTrack = () => {
      ensureLoopSegment();

      const list = segments();
      if (list.length < 2) return;

      const template = list[0];
      const viewportWidth = viewport.clientWidth;
      const shift = (list[1] as HTMLElement).offsetLeft;
      const minWidth = viewportWidth + shift;

      while (track.scrollWidth < minWidth) {
        const clone = template.cloneNode(true);
        if (clone instanceof HTMLElement) {
          clone.setAttribute("aria-hidden", "true");
          track.appendChild(clone);
        }
      }
    };

    const updateShift = () => {
      fillTrack();

      const list = segments();
      if (list.length < 2) return;

      const shift = (list[1] as HTMLElement).offsetLeft;
      if (shift <= 0) return;

      track.style.setProperty("--marquee-shift", `${shift}px`);
      track.classList.add("animate-marquee-scroll");
    };

    const waitForImages = () => {
      const images = track.querySelectorAll("img");
      const pending = [...images].filter((img) => !img.complete);

      if (pending.length === 0) {
        requestAnimationFrame(updateShift);
        return;
      }

      let loaded = 0;
      const onDone = () => {
        loaded += 1;
        if (loaded === pending.length) {
          requestAnimationFrame(updateShift);
        }
      };

      pending.forEach((img) => {
        img.addEventListener("load", onDone, { once: true });
        img.addEventListener("error", onDone, { once: true });
      });
    };

    waitForImages();

    const observer = new ResizeObserver(() => {
      requestAnimationFrame(updateShift);
    });
    observer.observe(viewport);

    window.addEventListener("resize", updateShift);
  }

  setupBrandsMarquee();
  document.addEventListener("astro:page-load", setupBrandsMarquee);
</script>
