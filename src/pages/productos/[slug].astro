---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ContactBanner from "../../components/ContactBanner.astro";
import FaqSection from "../../components/FaqSection.astro";
import { products } from "../../data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<Layout title={product.navLabel}>
  <Header />
  <main>
    <!-- Hero -->
    <section
      class="relative pt-32 pb-16 sm:pt-40 sm:pb-24 lg:pt-48 lg:pb-32 overflow-hidden"
    >
      <div class="absolute inset-0 z-0">
        <div
          class="absolute inset-0 bg-gradient-to-b from-zinc-50 via-white to-zinc-100/80"
        >
        </div>
        <div
          class="absolute inset-0 opacity-[0.02]"
          style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.12) 1px, transparent 0); background-size: 32px 32px;"
        >
        </div>
        <div
          class="absolute top-0 -right-32 w-[400px] sm:w-[500px] lg:w-[700px] h-[400px] sm:h-[500px] lg:h-[700px] bg-brand-500/5 rounded-full blur-[120px]"
        >
        </div>
        <div
          class="absolute bottom-0 -left-32 w-[300px] sm:w-[400px] h-[300px] sm:h-[400px] bg-amber-500/4 rounded-full blur-[100px]"
        >
        </div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="flex items-center gap-2 text-sm text-zinc-400 mb-6 animate-fade-in-up"
          style="animation-delay: 0.1s;"
        >
          <a href="/" class="hover:text-brand-600 transition-colors">Inicio</a>
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path></svg
          >
          <a href="/#productos" class="hover:text-brand-600 transition-colors"
            >Productos</a
          >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path></svg
          >
          <span class="text-zinc-500">{product.title}</span>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div
            class="lg:col-span-7 animate-fade-in-up"
            style="animation-delay: 0.2s;"
          >
            <div
              class={`inline-flex items-center justify-center w-16 h-16 rounded-2xl ${product.accent} mb-8`}
            >
              <Fragment set:html={product.icon} />
            </div>

            <h1
              class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold text-zinc-900 tracking-tight leading-tight mb-6"
            >
              {product.title}
            </h1>

            <p class="text-lg sm:text-xl text-zinc-500 leading-relaxed">
              {product.longDescription}
            </p>
          </div>

          <div
            class="lg:col-span-5 animate-fade-in-up"
            style="animation-delay: 0.35s;"
          >
            <div
              class="relative bg-white rounded-[2rem] sm:rounded-[2.5rem] p-8 sm:p-10 border border-zinc-200/70 shadow-xl shadow-zinc-200/30 overflow-hidden"
            >
              <div
                class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${product.color}`}
              >
              </div>
              <span
                class="text-7xl font-extrabold text-zinc-100 absolute top-6 right-8 select-none"
                >{product.number}</span
              >
              <h2 class="text-lg font-bold text-zinc-900 mb-6 relative z-10">
                Lo que ofrecemos
              </h2>
              <ul class="space-y-4 relative z-10">
                {
                  product.features.map((feature) => (
                    <li class="flex items-start gap-3 text-zinc-600">
                      <span
                        class={`flex-shrink-0 w-5 h-5 mt-0.5 rounded-full bg-gradient-to-br ${product.color} flex items-center justify-center`}
                      >
                        <svg
                          class="w-3 h-3 text-white"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="3"
                            d="M5 13l4 4L19 7"
                          />
                        </svg>
                      </span>
                      {feature}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Subcategories -->
    {
      product.subcategories && product.subcategories.length > 0 && (
        <section class="py-16 sm:py-20 bg-white">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
              <span
                class={`inline-block px-3 py-1 text-xs font-bold ${product.accent} mb-6 tracking-wider rounded-full`}
              >
                Categorías
              </span>
              <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-zinc-900 tracking-tight">
                Explora nuestras opciones
              </h2>
            </div>
            <div class="subcategories-grid grid sm:grid-cols-2 gap-6 lg:gap-8">
              {product.subcategories.map((sub, idx) => (
                <div
                  class={`group relative bg-white rounded-2xl sm:rounded-3xl p-8 border border-zinc-200/70 hover:border-brand-200/60 hover:shadow-xl hover:shadow-zinc-200/30 hover:-translate-y-1 transition-all duration-500 animate-fade-in-up overflow-hidden`}
                  style={`animation-delay: ${0.15 + idx * 0.1}s;`}
                >
                  <div
                    class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${product.color} rounded-t-2xl sm:rounded-t-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500`}
                  />
                  <h3 class="text-xl font-bold text-zinc-900 mb-3">
                    {sub.title}
                  </h3>
                  <p class="text-zinc-500 leading-relaxed">{sub.description}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Other products -->
    <section class="py-16 sm:py-20 bg-zinc-50/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2
          class="text-2xl sm:text-3xl font-extrabold text-zinc-900 tracking-tight mb-10 text-center"
        >
          Otros servicios
        </h2>
        <div class="grid sm:grid-cols-3 gap-4 sm:gap-6">
          {
            products
              .filter((p) => p.slug !== product.slug)
              .map((p) => (
                <a
                  href={`/productos/${p.slug}`}
                  class="group bg-white rounded-2xl p-6 border border-zinc-200/70 hover:border-brand-200/60 hover:shadow-xl hover:shadow-zinc-200/30 hover:-translate-y-1 transition-all duration-500"
                >
                  <div
                    class={`inline-flex items-center justify-center w-12 h-12 rounded-xl ${p.accent} mb-4 group-hover:scale-110 transition-transform duration-500`}
                  >
                    <Fragment set:html={p.icon} />
                  </div>
                  <h3 class="font-bold text-zinc-900 group-hover:text-brand-600 transition-colors">
                    {p.title}
                  </h3>
                  <p class="text-sm text-zinc-500 mt-2 line-clamp-2">
                    {p.description}
                  </p>
                </a>
              ))
          }
        </div>
      </div>
    </section>

    <FaqSection faqs={product.faqs} />
  </main>
  <ContactBanner
    headline={product.ctaHeadline ??
      `¿Interesado en ${product.title.toLowerCase()}?`}
    subtext={product.ctaSubtext ??
      "Cuéntanos los detalles de tu proyecto y te enviamos una cotización personalizada sin compromiso."}
  />
  <Footer />
</Layout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  @media (min-width: 640px) {
    .subcategories-grid > *:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      justify-self: center;
      max-width: 50%;
    }
  }
</style>
