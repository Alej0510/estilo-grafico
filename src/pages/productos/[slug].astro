---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import ContactBanner from "../../components/ContactBanner.astro";
import FaqSection from "../../components/FaqSection.astro";
import ServiceIcon from "../../components/icons/ServiceIcon.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Arrow from "../../components/icons/Arrow.astro";
import { products } from "../../data/products";
import { productSeoDescription, productSeoTitle } from "../../data/site";
import {
  breadcrumbSchema,
  faqSchema,
  serviceSchema,
} from "../../lib/structured-data";
import packagingImage from "../../assets/packaging-design.webp";
import printQualityImage from "../../assets/print-quality.webp";
import adBoardImage from "../../assets/ad-board.webp";
import graphicDesignImage from "../../assets/graphic-design.webp";
import bolsasImage from "../../assets/bolsas.jpg";
import cajasImage from "../../assets/cajas.jpg";
import etiquetasStickerImage from "../../assets/etiquetas-sticker.jpg";
import etiquetasPapelImage from "../../assets/etiquetas-papel.jpg";
import catalogoImage from "../../assets/catalogo.jpg";
import libroImage from "../../assets/libro.jpg";
import brochureImage from "../../assets/brochure.jpg";
import carpetaImage from "../../assets/carpeta.jpg";
import flyerImage from "../../assets/flyer.jpg";
import tarjetaPresentacionImage from "../../assets/tarjeta-presentacion.jpg";
import aficheImage from "../../assets/afiche.jpg";
import bannerImage from "../../assets/banner.jpg";
import lonaImage from "../../assets/lona.jpg";
import viniloImage from "../../assets/vinilo.jpg";
import fotografiaImage from "../../assets/fotografia.jpg";
import websiteImage from "../../assets/website.jpg";
import vallaImage from "../../assets/valla.jpg";
import avisoLuminosoImage from "../../assets/aviso-luminoso.jpg";
import senalizacionImage from "../../assets/senalizacion.jpg";
import viniloComercialImage from "../../assets/vinilo-comercial.jpg";
import viniloVehicularImage from "../../assets/vinilo-vehicular.jpg";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

const serviceImages: Record<string, { src: ImageMetadata; alt: string }> = {
  "etiquetas-empaques": {
    src: packagingImage,
    alt: "Etiquetas y empaques personalizados en Medellín — Estilo Gráfico",
  },
  "material-impreso": {
    src: printQualityImage,
    alt: "Material impreso litográfico en Medellín — Estilo Gráfico",
  },
  "gran-formato": {
    src: adBoardImage,
    alt: "Impresión gran formato en Medellín — Estilo Gráfico",
  },
  "diseno-imagen": {
    src: graphicDesignImage,
    alt: "Diseño gráfico e imagen en Medellín — Estilo Gráfico",
  },
};

const productImage = serviceImages[product.slug];

const subcategoryImages: Record<
  string,
  Record<string, { src: ImageMetadata | string; alt: string }>
> = {
  "etiquetas-empaques": {
    Bolsas: {
      src: bolsasImage,
      alt: "Bolsas personalizadas en Medellín — Estilo Gráfico",
    },
    Cajas: {
      src: cajasImage,
      alt: "Cajas personalizadas en Medellín — Estilo Gráfico",
    },
    "Etiquetas Adhesivas": {
      src: etiquetasStickerImage,
      alt: "Etiquetas adhesivas personalizadas en Medellín — Estilo Gráfico",
    },
    "Etiquetas en Papel": {
      src: etiquetasPapelImage,
      alt: "Etiquetas en papel personalizadas en Medellín — Estilo Gráfico",
    },
  },
  "material-impreso": {
    Catálogos: {
      src: catalogoImage,
      alt: "Catálogos impresos personalizados en Medellín — Estilo Gráfico",
    },
    Libros: {
      src: libroImage,
      alt: "Impresión de libros en Medellín — Estilo Gráfico",
    },
    "Brochures y Plegables": {
      src: brochureImage,
      alt: "Brochures y plegables impresos personalizados en Medellín — Estilo Gráfico",
    },
    Carpetas: {
      src: carpetaImage,
      alt: "Carpetas personalizadas en Medellín — Estilo Gráfico",
    },
    Flyers: {
      src: flyerImage,
      alt: "Flyers impresos personalizados en Medellín — Estilo Gráfico",
    },
    "Tarjetas de Presentación": {
      src: tarjetaPresentacionImage,
      alt: "Tarjetas de presentación personalizadas en Medellín — Estilo Gráfico",
    },
  },
  "diseno-imagen": {
    Afiches: {
      src: aficheImage,
      alt: "Afiches a gran formato en Medellín — Estilo Gráfico",
    },
    Banners: {
      src: bannerImage,
      alt: "Banners personalizados en Medellín — Estilo Gráfico",
    },
    Lonas: {
      src: lonaImage,
      alt: "Lonas impresas a gran formato en Medellín — Estilo Gráfico",
    },
    Vinilos: {
      src: viniloImage,
      alt: "Vinilos a gran formato en Medellín — Estilo Gráfico",
    },
    "Fotografía y Video": {
      src: fotografiaImage,
      alt: "Fotografía y video profesional en Medellín — Estilo Gráfico",
    },
    "Diseño de página web": {
      src: websiteImage,
      alt: "Diseño de páginas web en Medellín — Estilo Gráfico",
    },
  },
  "gran-formato": {
    Vallas: {
      src: vallaImage,
      alt: "Vallas publicitarias en Medellín — Estilo Gráfico",
    },
    "Avisos luminosos y Neoflex": {
      src: avisoLuminosoImage,
      alt: "Avisos luminosos LED y Neoflex en Medellín — Estilo Gráfico",
    },
    Señalización: {
      src: senalizacionImage,
      alt: "Señalización comercial en Medellín — Estilo Gráfico",
    },
    "Vinilo comercial": {
      src: viniloComercialImage,
      alt: "Vinilo comercial para negocios en Medellín — Estilo Gráfico",
    },
    "Vinilo vehicular": {
      src: viniloVehicularImage,
      alt: "Vinilo vehicular en Medellín — Estilo Gráfico",
    },
  },
};

const productSubcategoryImages = subcategoryImages[product.slug];

const brandGradient = "from-brand-500 to-brand-600";

const cardBase =
  "group relative bg-white rounded-2xl lg:rounded-3xl hover:shadow-2xl hover:shadow-black/25 transition-all duration-500 border border-zinc-100 hover:border-brand-200/50 overflow-hidden";

const otherProducts = products.filter((p) => p.slug !== product.slug);

const productPath = `/productos/${product.slug}`;
const seoTitle = productSeoTitle(product.navLabel);
const seoDescription = productSeoDescription(product.description);
const structuredData = [
  breadcrumbSchema([
    { name: "Inicio", path: "/" },
    { name: "Productos", path: "/#productos" },
    { name: product.title, path: productPath },
  ]),
  serviceSchema(product.title, product.description, productPath),
  faqSchema(product.faqs),
];
---

<Layout
  title={seoTitle}
  description={seoDescription}
  path={productPath}
  structuredData={structuredData}
>
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-8 sm:pb-12 lg:pb-16 overflow-hidden">
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <Breadcrumb
          class="mb-8 animate-fade-in-up"
          style="animation-delay: 0.1s;"
          items={[
            { label: "Inicio", href: "/" },
            { label: "Productos", href: "/#productos" },
            { label: product.title, shortLabel: product.navLabel },
          ]}
        />

        <div
          class="relative bg-white rounded-4xl sm:rounded-[2.5rem] lg:rounded-[3rem] border border-zinc-200/70 shadow-2xl shadow-black/20 overflow-hidden animate-fade-in-up"
          style="animation-delay: 0.2s;"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-zinc-50/80 via-white to-brand-50/20 pointer-events-none"
          >
          </div>
          <div
            class="absolute top-0 left-[8%] right-[8%] h-px bg-linear-to-r from-transparent via-brand-400/40 to-transparent"
          >
          </div>

          <div
            class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 xl:gap-16 items-center p-6 sm:p-8 lg:p-12 xl:p-14"
          >
            <div class="min-w-0 order-2 lg:order-1">
              <h1
                class="text-3xl sm:text-4xl lg:text-[2.75rem] xl:text-5xl font-extrabold text-zinc-900 tracking-tight leading-tight mb-5"
              >
                {product.title}
              </h1>

              <p
                class="text-base sm:text-lg text-zinc-500 leading-relaxed max-w-xl"
              >
                {product.longDescription}
              </p>
            </div>

            {
              productImage && (
                <div class="relative order-1 lg:order-2 rounded-2xl sm:rounded-3xl overflow-hidden shadow-xl shadow-black/25 aspect-4/3 lg:aspect-auto lg:min-h-[320px]">
                  <Image
                    src={productImage.src}
                    alt={productImage.alt}
                    class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 hover:scale-105"
                    widths={[480, 640, 960]}
                    sizes="(max-width: 1024px) 100vw, 50vw"
                    loading="eager"
                    decoding="async"
                  />
                  <div class="absolute inset-0 bg-linear-to-t from-zinc-900/20 via-transparent to-transparent" />
                  <div class="absolute inset-0 ring-1 ring-inset ring-black/10" />
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Subcategories -->
    {
      product.subcategories && product.subcategories.length > 0 && (
        <section class="py-16 sm:py-20 relative">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
              <span
                class={`inline-block px-3 py-1 text-gray-100 sm:text-lg font-bold ${product.accent} mb-3 tracking-wider`}
              >
                Categorías
              </span>
              <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-brand-500 tracking-tight">
                Explora nuestras opciones
              </h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
              {product.subcategories.map((sub, idx) => {
                const subImage = productSubcategoryImages?.[sub.title];
                return (
                  <div
                    class="group relative flex flex-col bg-white rounded-2xl sm:rounded-3xl border border-zinc-200/70 hover:border-brand-200/60 hover:shadow-xl hover:shadow-black/15 hover:-translate-y-1 transition-all duration-500 animate-fade-in-up overflow-hidden"
                    style={`animation-delay: ${0.15 + idx * 0.1}s;`}
                  >
                    <div class="relative aspect-3/2 bg-zinc-200 shrink-0 overflow-hidden">
                      {subImage ? (
                        typeof subImage.src === "string" ? (
                          <img
                            src={subImage.src}
                            alt={subImage.alt}
                            class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                            loading="lazy"
                            decoding="async"
                            referrerpolicy="no-referrer"
                          />
                        ) : (
                          <Image
                            src={subImage.src}
                            alt={subImage.alt}
                            class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                            widths={[400, 640, 800]}
                            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                            loading="lazy"
                            decoding="async"
                          />
                        )
                      ) : (
                        <div
                          class="absolute inset-0"
                          role="img"
                          aria-label={`Imagen de ${sub.title}`}
                        />
                      )}
                      <div class="absolute inset-0 bg-linear-to-t from-zinc-900/10 via-transparent to-transparent" />
                      <div class="absolute inset-0 ring-1 ring-inset ring-black/5" />
                    </div>
                    <div class="p-6 sm:p-8">
                      <h3 class="text-xl font-bold text-zinc-900 mb-3">
                        {sub.title}
                      </h3>
                      <p class="text-zinc-500 leading-relaxed">
                        {sub.description}
                      </p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </section>
      )
    }

    <FaqSection faqs={product.faqs} />

    <!-- Other products -->
    <section class="py-16 sm:py-20 lg:py-28 relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 lg:mb-16">
          <span
            class="inline-block px-3 py-1 text-base sm:text-lg font-bold text-gray-300 mb-2 tracking-wider"
          >
            Explora más
          </span>
          <h2
            class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-gray-100 tracking-tight"
          >
            Otros servicios
          </h2>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6"
        >
          {
            otherProducts.map((p, index) => (
              <a
                href={`/productos/${p.slug}`}
                class={`${cardBase} flex flex-col animate-fade-in-up`}
                style={`animation-delay: ${0.1 + index * 0.1}s;`}
              >
                <div
                  class={`absolute inset-0 bg-linear-to-br ${brandGradient} opacity-0 group-hover:opacity-[0.03] transition-opacity duration-500 pointer-events-none`}
                />
                <div
                  class={`absolute top-0 right-0 w-24 h-24 bg-linear-to-bl ${brandGradient} opacity-0 group-hover:opacity-10 transition-opacity duration-500 rounded-bl-[80px] pointer-events-none`}
                />

                <div class="relative z-10 flex flex-col flex-1 p-5 sm:p-6">
                  <div class="flex items-start justify-between mb-4">
                    <div
                      class={`inline-flex items-center justify-center p-3 rounded-xl bg-linear-to-br ${brandGradient} text-white shadow-md group-hover:scale-105 group-hover:shadow-lg transition-all duration-500`}
                    >
                      <ServiceIcon slug={p.slug} class="w-6 h-6" />
                    </div>
                    <span class="text-4xl font-extrabold text-zinc-100 group-hover:text-brand-600/20 transition-colors duration-500 select-none leading-none">
                      {p.number}
                    </span>
                  </div>

                  <h3 class="text-lg font-bold text-zinc-900 mb-2 group-hover:text-brand-600 transition-colors duration-300 line-clamp-2">
                    {p.title}
                  </h3>

                  <p class="text-sm text-zinc-500 leading-relaxed mb-4 flex-1 line-clamp-3">
                    {p.description}
                  </p>

                  <div class="flex items-center gap-2 text-sm font-medium text-brand-600 opacity-0 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-500">
                    <span>Conocer más</span>
                    <Arrow
                      to="right"
                      class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
                    />
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <ContactBanner
    headline={product.ctaHeadline ??
      `¿Interesado en ${product.title.toLowerCase()}?`}
    subtext={product.ctaSubtext ??
      "Cuéntanos los detalles de tu proyecto y te enviamos una cotización personalizada sin compromiso."}
  />
</Layout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
