---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import ContactBanner from "../../components/ContactBanner.astro";
import FaqSection from "../../components/FaqSection.astro";
import ServiceIcon from "../../components/icons/ServiceIcon.astro";
import Chevron from "../../components/icons/Chevron.astro";
import Arrow from "../../components/icons/Arrow.astro";
import { products } from "../../data/products";
import { productSeoDescription, productSeoTitle } from "../../data/site";
import {
  breadcrumbSchema,
  faqSchema,
  serviceSchema,
} from "../../lib/structured-data";
import packagingImage from "../../assets/packaging-design.webp";
import printQualityImage from "../../assets/print-quality.webp";
import adBoardImage from "../../assets/ad-board.webp";
import graphicDesignImage from "../../assets/graphic-design.webp";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

const serviceImages: Record<string, { src: ImageMetadata; alt: string }> = {
  "etiquetas-empaques": {
    src: packagingImage,
    alt: "Etiquetas y empaques personalizados en Medellín — Estilo Gráfico",
  },
  "material-impreso": {
    src: printQualityImage,
    alt: "Material impreso litográfico en Medellín — Estilo Gráfico",
  },
  "gran-formato": {
    src: adBoardImage,
    alt: "Impresión gran formato en Medellín — Estilo Gráfico",
  },
  "diseno-imagen": {
    src: graphicDesignImage,
    alt: "Diseño gráfico e imagen en Medellín — Estilo Gráfico",
  },
};

const productImage = serviceImages[product.slug];

const brandGradient = "from-brand-500 to-brand-600";

const cardBase =
  "group relative bg-white rounded-2xl lg:rounded-3xl hover:shadow-2xl hover:shadow-zinc-200/50 transition-all duration-500 border border-zinc-100 hover:border-brand-200/50 overflow-hidden";

const otherProducts = products.filter((p) => p.slug !== product.slug);

const productPath = `/productos/${product.slug}`;
const seoTitle = productSeoTitle(product.navLabel);
const seoDescription = productSeoDescription(product.description);
const structuredData = [
  breadcrumbSchema([
    { name: "Inicio", path: "/" },
    { name: "Productos", path: "/#productos" },
    { name: product.title, path: productPath },
  ]),
  serviceSchema(product.title, product.description, productPath),
  faqSchema(product.faqs),
];
---

<Layout
  title={seoTitle}
  description={seoDescription}
  path={productPath}
  structuredData={structuredData}
>
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-8 sm:pb-12 lg:pb-16 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div
          class="absolute inset-0 bg-linear-to-b from-zinc-50 via-white to-zinc-100/80"
        >
        </div>
        <div
          class="absolute inset-0 opacity-[0.02]"
          style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.12) 1px, transparent 0); background-size: 32px 32px;"
        >
        </div>
        <div
          class="absolute top-0 -right-32 w-[400px] sm:w-[500px] lg:w-[700px] h-[400px] sm:h-[500px] lg:h-[700px] bg-brand-500/5 rounded-full blur-[120px]"
        >
        </div>
        <div
          class="absolute bottom-0 -left-32 w-[300px] sm:w-[400px] h-[300px] sm:h-[400px] bg-amber-500/4 rounded-full blur-[100px]"
        >
        </div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav
          class="flex items-center gap-2 text-sm text-zinc-400 mb-8 animate-fade-in-up"
          style="animation-delay: 0.1s;"
          aria-label="Ruta de navegación"
        >
          <a href="/" class="hover:text-brand-600 transition-colors">Inicio</a>
          <Chevron to="right" class="w-4 h-4" />
          <a href="/#productos" class="hover:text-brand-600 transition-colors"
            >Productos</a
          >
          <Chevron to="right" class="w-4 h-4" />
          <span class="text-zinc-500">{product.title}</span>
        </nav>

        <div
          class="relative bg-white rounded-4xl sm:rounded-[2.5rem] lg:rounded-[3rem] border border-zinc-200/70 shadow-2xl shadow-zinc-200/40 overflow-hidden animate-fade-in-up"
          style="animation-delay: 0.2s;"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-zinc-50/80 via-white to-brand-50/20 pointer-events-none"
          >
          </div>
          <div
            class="absolute top-0 left-[8%] right-[8%] h-px bg-linear-to-r from-transparent via-brand-400/40 to-transparent"
          >
          </div>

          <div
            class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 xl:gap-16 items-center p-6 sm:p-8 lg:p-12 xl:p-14"
          >
            <div class="min-w-0 order-2 lg:order-1">
              <h1
                class="text-3xl sm:text-4xl lg:text-[2.75rem] xl:text-5xl font-extrabold text-zinc-900 tracking-tight leading-tight mb-5"
              >
                {product.title}
              </h1>

              <p
                class="text-base sm:text-lg text-zinc-500 leading-relaxed max-w-xl"
              >
                {product.longDescription}
              </p>
            </div>

            {
              productImage && (
                <div class="relative order-1 lg:order-2 rounded-2xl sm:rounded-3xl overflow-hidden shadow-xl shadow-zinc-200/50 aspect-4/3 lg:aspect-auto lg:min-h-[320px]">
                  <Image
                    src={productImage.src}
                    alt={productImage.alt}
                    class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 hover:scale-105"
                    widths={[480, 640, 960]}
                    sizes="(max-width: 1024px) 100vw, 50vw"
                    loading="eager"
                    decoding="async"
                  />
                  <div class="absolute inset-0 bg-linear-to-t from-zinc-900/20 via-transparent to-transparent" />
                  <div class="absolute inset-0 ring-1 ring-inset ring-black/10" />
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Subcategories -->
    {
      product.subcategories && product.subcategories.length > 0 && (
        <section class="py-16 sm:py-20 bg-white">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
              <span
                class={`inline-block px-3 py-1 text-base sm:text-lg font-bold ${product.accent} mb-3 tracking-wider`}
              >
                Categorías
              </span>
              <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-zinc-900 tracking-tight">
                Explora nuestras opciones
              </h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
              {product.subcategories.map((sub, idx) => (
                <div
                  class="group relative flex flex-col bg-white rounded-2xl sm:rounded-3xl border border-zinc-200/70 hover:border-brand-200/60 hover:shadow-xl hover:shadow-zinc-200/30 hover:-translate-y-1 transition-all duration-500 animate-fade-in-up overflow-hidden"
                  style={`animation-delay: ${0.15 + idx * 0.1}s;`}
                >
                  <div
                    class="relative aspect-3/2 bg-zinc-200 shrink-0"
                    role="img"
                    aria-label={`Imagen de ${sub.title}`}
                  >
                    <div class="absolute inset-0 ring-1 ring-inset ring-black/5" />
                  </div>
                  <div class="p-6 sm:p-8">
                    <h3 class="text-xl font-bold text-zinc-900 mb-3">
                      {sub.title}
                    </h3>
                    <p class="text-zinc-500 leading-relaxed">
                      {sub.description}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <FaqSection faqs={product.faqs} />

    <!-- Other products -->
    <section class="py-16 sm:py-20 lg:py-28 bg-zinc-50/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 lg:mb-16">
          <span
            class="inline-block px-3 py-1 text-base sm:text-lg font-bold text-brand-600 mb-2 tracking-wider"
          >
            Explora más
          </span>
          <h2
            class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-zinc-900 tracking-tight"
          >
            Otros servicios
          </h2>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6"
        >
          {
            otherProducts.map((p, index) => (
              <a
                href={`/productos/${p.slug}`}
                class={`${cardBase} flex flex-col animate-fade-in-up`}
                style={`animation-delay: ${0.1 + index * 0.1}s;`}
              >
                <div
                  class={`absolute inset-0 bg-linear-to-br ${brandGradient} opacity-0 group-hover:opacity-[0.03] transition-opacity duration-500 pointer-events-none`}
                />
                <div
                  class={`absolute top-0 right-0 w-24 h-24 bg-linear-to-bl ${brandGradient} opacity-0 group-hover:opacity-10 transition-opacity duration-500 rounded-bl-[80px] pointer-events-none`}
                />

                <div class="relative z-10 flex flex-col flex-1 p-5 sm:p-6">
                  <div class="flex items-start justify-between mb-4">
                    <div
                      class={`inline-flex items-center justify-center p-3 rounded-xl bg-linear-to-br ${brandGradient} text-white shadow-md group-hover:scale-105 group-hover:shadow-lg transition-all duration-500`}
                    >
                      <ServiceIcon slug={p.slug} class="w-6 h-6" />
                    </div>
                    <span class="text-4xl font-extrabold text-zinc-100 group-hover:text-brand-600/20 transition-colors duration-500 select-none leading-none">
                      {p.number}
                    </span>
                  </div>

                  <h3 class="text-lg font-bold text-zinc-900 mb-2 group-hover:text-brand-600 transition-colors duration-300 line-clamp-2">
                    {p.title}
                  </h3>

                  <p class="text-sm text-zinc-500 leading-relaxed mb-4 flex-1 line-clamp-3">
                    {p.description}
                  </p>

                  <div class="flex items-center gap-2 text-sm font-medium text-brand-600 opacity-0 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-500">
                    <span>Conocer más</span>
                    <Arrow
                      to="right"
                      class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
                    />
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <ContactBanner
    headline={product.ctaHeadline ??
      `¿Interesado en ${product.title.toLowerCase()}?`}
    subtext={product.ctaSubtext ??
      "Cuéntanos los detalles de tu proyecto y te enviamos una cotización personalizada sin compromiso."}
  />
</Layout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
