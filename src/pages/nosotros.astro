---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ContactBanner from "../components/ContactBanner.astro";
import Arrow from "../components/icons/Arrow.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Section from "../components/Section.astro";
import SectionCard from "../components/SectionCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import HeroCard from "../components/HeroCard.astro";
import ContentCard from "../components/ContentCard.astro";
import BadgeCheck from "../components/icons/BadgeCheck.astro";
import Sparkles from "../components/icons/Sparkles.astro";
import Users from "../components/icons/Users.astro";
import Lightning from "../components/icons/Lightning.astro";
import Heart from "../components/icons/Heart.astro";
import Eye from "../components/icons/Eye.astro";
import aboutUs1 from "../assets/about-us-1.webp";
import aboutUs2 from "../assets/about-us-2.webp";
import { PAGE_SEO } from "../data/site";
import { breadcrumbSchema } from "../lib/structured-data";

const year = new Date().getFullYear();
const yearsSince = year - 2007;

const stats = [
  { value: String(yearsSince), label: "Años de experiencia" },
  { value: "500+", label: "Clientes satisfechos" },
  { value: "100%", label: "Compromiso con calidad" },
];

const values = [
  {
    title: "Calidad",
    description:
      "Materiales premium y control riguroso en cada etapa del proceso de impresión.",
    Icon: BadgeCheck,
  },
  {
    title: "Creatividad",
    description:
      "Diseños que comunican, destacan y dan vida a la identidad de cada marca.",
    Icon: Sparkles,
  },
  {
    title: "Compromiso",
    description:
      "Acompañamos cada proyecto de principio a fin con asesoría personalizada.",
    Icon: Users,
  },
  {
    title: "Innovación",
    description:
      "Tecnología de punta y procesos optimizados para resultados impecables.",
    Icon: Lightning,
  },
  {
    title: "Sostenibilidad",
    description:
      "Prácticas responsables que cuidan el entorno sin comprometer la excelencia.",
    Icon: Heart,
  },
];
---

<Layout
  title={PAGE_SEO.nosotros.title}
  description={PAGE_SEO.nosotros.description}
  path="/nosotros"
  structuredData={[
    breadcrumbSchema([
      { name: "Inicio", path: "/" },
      { name: "Nosotros", path: "/nosotros" },
    ]),
  ]}
>
  <main>
    <!-- ========== HERO ========== -->
    <section class="relative pt-32 pb-8 sm:pb-12 lg:pb-16 overflow-hidden">
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <Breadcrumb
          class="mb-8 ml-3 animate-reveal"
          style="animation-delay: 0.05s;"
          items={[{ label: "Inicio", href: "/" }, { label: "Nosotros" }]}
        />

        <HeroCard class="animate-reveal" style="animation-delay: 0.1s;">
          <div
            class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 xl:gap-16 items-center"
          >
            <!-- Copy -->
            <div class="min-w-0 order-1">
              <div
                class="animate-reveal flex items-center gap-3 mb-6"
                style="animation-delay: 0.15s;"
              >
                <span class="block w-8 h-px bg-brand-500" aria-hidden="true"
                ></span>
                <span
                  class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-600"
                >
                  Nuestra historia
                </span>
              </div>

              <h1
                class="animate-reveal text-[2rem] leading-[1.08] sm:text-4xl lg:text-5xl xl:text-[3.25rem] font-extrabold text-zinc-900 tracking-[-0.02em] mb-6"
                style="animation-delay: 0.2s;"
              >
                Empresa de
                <span
                  class="text-transparent bg-clip-text bg-linear-to-r from-brand-500 via-brand-600 to-amber-600"
                >
                  litografía
                </span>
                en Medellín
              </h1>

              <p
                class="animate-reveal text-base sm:text-lg text-zinc-500 leading-relaxed mb-6"
                style="animation-delay: 0.27s;"
              >
                Comenzamos a innovar en el mundo de la litografía y hoy somos
                una compañía líder en soluciones creativas para empresas que
                buscan destacar. Cada proyecto es una oportunidad de superar
                expectativas.
              </p>

              <p
                class="animate-reveal text-base text-zinc-400 leading-relaxed mb-8"
                style="animation-delay: 0.33s;"
              >
                En Estilo Gráfico unimos precisión técnica, diseño profesional y
                un trato cercano para convertir conceptos en impresiones de alto
                impacto.
              </p>

              <div class="animate-reveal" style="animation-delay: 0.39s;">
                <a
                  href="/#productos"
                  class="relative inline-flex items-center justify-center px-7 py-3.5 overflow-hidden rounded-full font-bold text-sm sm:text-base text-zinc-900 group"
                >
                  <div
                    class="absolute inset-0 bg-linear-to-r from-brand-500 to-brand-600 transition-transform duration-500 group-hover:scale-105"
                  >
                  </div>
                  <span class="relative z-10 flex items-center gap-2">
                    Conoce nuestros servicios
                    <span
                      class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5"
                    >
                      <Arrow to="right" class="w-4 h-4" />
                    </span>
                  </span>
                </a>
              </div>
            </div>

            <!-- Hero image -->
            <div
              class="relative min-w-0 order-2 mt-8 lg:mt-0 animate-reveal max-w-xs sm:max-w-sm lg:max-w-md mx-auto lg:mx-0 lg:ml-auto"
              style="animation-delay: 0.25s;"
            >
              <div
                class="relative aspect-3/4 rounded-3xl sm:rounded-4xl overflow-hidden"
              >
                <Image
                  src={aboutUs1}
                  alt="Equipo de Estilo Gráfico en nuestro taller de impresión"
                  class="w-full h-full object-cover object-center"
                  loading="eager"
                  fetchpriority="high"
                />
                <div
                  class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl sm:rounded-4xl pointer-events-none"
                >
                </div>
              </div>
            </div>
          </div>
        </HeroCard>

        <!-- Stats strip -->
        <div
          class="relative -mt-4 sm:-mt-6 mx-2 sm:mx-6 lg:mx-10 animate-reveal"
          style="animation-delay: 0.45s;"
        >
          <div
            class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-zinc-200/80 rounded-2xl sm:rounded-3xl overflow-hidden border border-zinc-200/70 shadow-xl shadow-black/20"
          >
            {
              stats.map(({ value, label }) => (
                <div class="bg-white px-6 py-6 sm:py-7 text-center sm:text-left lg:text-center">
                  <div class="text-3xl sm:text-4xl font-extrabold text-zinc-900 tracking-tight">
                    {value}
                  </div>
                  <div class="text-sm text-zinc-500 mt-1">{label}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ========== MISSION & VISION ========== -->
    <Section>
      <SectionCard>
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 lg:items-stretch">
          <!-- Image column -->
          <div class="lg:col-span-5 flex h-full min-h-[240px] sm:min-h-[280px]">
            <div
              class="relative w-full h-full rounded-3xl sm:rounded-4xl overflow-hidden shadow-2xl shadow-black/15"
            >
              <Image
                src={aboutUs2}
                alt="Proceso de impresión y producción gráfica de alta calidad"
                class="absolute inset-0 w-full h-full object-cover object-center"
                loading="lazy"
              />
              <div
                class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl sm:rounded-4xl pointer-events-none"
              >
              </div>
            </div>
          </div>

          <!-- Cards column -->
          <div class="lg:col-span-7 flex flex-col gap-6 sm:gap-8 h-full">
            <ContentCard padding="p-8 sm:p-10">
              <div
                class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-brand-500/10 text-brand-600 mb-6"
              >
                <Lightning class="w-7 h-7" />
              </div>
              <h2
                class="text-2xl sm:text-3xl font-extrabold text-zinc-900 mb-4"
              >
                Nuestra misión
              </h2>
              <p class="text-lg text-zinc-500 leading-relaxed">
                Somos una empresa de litografía dedicada a transformar tus ideas
                en impresiones de alta calidad, combinando creatividad y
                tecnología avanzada para ofrecer soluciones personalizadas que
                impulsen tu marca.
              </p>
            </ContentCard>

            <ContentCard padding="p-8 sm:p-10">
              <div
                class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-amber-500/10 text-amber-600 mb-6"
              >
                <Eye class="w-7 h-7" />
              </div>
              <h2
                class="text-2xl sm:text-3xl font-extrabold text-zinc-900 mb-4"
              >
                Nuestra visión
              </h2>
              <p class="text-lg text-zinc-500 leading-relaxed">
                Con más de {yearsSince} años de experiencia en el sector gráfico,
                nos enorgullece ser un referente en impresión y diseño, comprometidos
                con la excelencia, la innovación continua y la satisfacción de nuestros
                clientes.
              </p>
            </ContentCard>
          </div>
        </div>
      </SectionCard>
    </Section>

    <!-- ========== VALUES ========== -->
    <Section aria-labelledby="values-heading">
      <SectionCard>
        <div class="flex flex-col gap-8 lg:gap-10">
          <SectionHeader
            eyebrow="Lo que nos define"
            decorated
            id="values-heading"
          >
            Nuestros valores,
            <span
              class="text-transparent bg-clip-text bg-linear-to-r from-brand-500 to-amber-600"
            >
              nuestra esencia
            </span>
          </SectionHeader>

          <div class="flex flex-col gap-4 sm:gap-5 lg:gap-6">
            <div
              class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 lg:gap-6"
            >
              {
                values.slice(0, 3).map(({ title, description, Icon }) => (
                  <ContentCard>
                    <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-2xl bg-linear-to-br from-brand-500/10 to-amber-500/10 text-brand-600 mb-5 group-hover:scale-110 transition-transform duration-500">
                      <Icon class="w-6 h-6" />
                    </div>
                    <h3 class="text-lg sm:text-xl font-extrabold text-zinc-900 mb-2">
                      {title}
                    </h3>
                    <p class="text-sm sm:text-base text-zinc-500 leading-relaxed">
                      {description}
                    </p>
                  </ContentCard>
                ))
              }
            </div>

            <div
              class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5 lg:gap-6"
            >
              {
                values.slice(3).map(({ title, description, Icon }) => (
                  <ContentCard>
                    <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-2xl bg-linear-to-br from-brand-500/10 to-amber-500/10 text-brand-600 mb-5 group-hover:scale-110 transition-transform duration-500">
                      <Icon class="w-6 h-6" />
                    </div>
                    <h3 class="text-lg sm:text-xl font-extrabold text-zinc-900 mb-2">
                      {title}
                    </h3>
                    <p class="text-sm sm:text-base text-zinc-500 leading-relaxed">
                      {description}
                    </p>
                  </ContentCard>
                ))
              }
            </div>
          </div>
        </div>
      </SectionCard>
    </Section>

    <ContactBanner
      headline="¿Listo para transformar tus ideas en realidad?"
      subtext="Contáctanos y descubre cómo podemos ayudarte con tus necesidades de impresión y diseño."
    />
  </main>
</Layout>
