---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ContactBanner from "../components/ContactBanner.astro";
import Footer from "../components/Footer.astro";
import Arrow from "../components/icons/Arrow.astro";
import Chevron from "../components/icons/Chevron.astro";
import BadgeCheck from "../components/icons/BadgeCheck.astro";
import Sparkles from "../components/icons/Sparkles.astro";
import Users from "../components/icons/Users.astro";
import Lightning from "../components/icons/Lightning.astro";
import Heart from "../components/icons/Heart.astro";
import Eye from "../components/icons/Eye.astro";
import aboutUs1 from "../assets/about-us-1.webp";
import aboutUs2 from "../assets/about-us-2.webp";

const year = new Date().getFullYear();
const yearsSince = year - 2007;

const stats = [
  { value: String(yearsSince), label: "Años de experiencia" },
  { value: "500+", label: "Clientes satisfechos" },
  { value: "100%", label: "Compromiso con calidad" },
];

const values = [
  {
    title: "Calidad",
    description:
      "Materiales premium y control riguroso en cada etapa del proceso de impresión.",
    Icon: BadgeCheck,
  },
  {
    title: "Creatividad",
    description:
      "Diseños que comunican, destacan y dan vida a la identidad de cada marca.",
    Icon: Sparkles,
  },
  {
    title: "Compromiso",
    description:
      "Acompañamos cada proyecto de principio a fin con asesoría personalizada.",
    Icon: Users,
  },
  {
    title: "Innovación",
    description:
      "Tecnología de punta y procesos optimizados para resultados impecables.",
    Icon: Lightning,
  },
  {
    title: "Sostenibilidad",
    description:
      "Prácticas responsables que cuidan el entorno sin comprometer la excelencia.",
    Icon: Heart,
  },
];
---

<Layout title="Nosotros">
  <Header />
  <main>
    <!-- ========== HERO ========== -->
    <section class="relative pt-32 pb-8 sm:pb-12 lg:pb-16 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div
          class="absolute inset-0 bg-linear-to-b from-zinc-50 via-white to-zinc-100/80"
        >
        </div>
        <div
          class="absolute inset-0 opacity-[0.02]"
          style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.12) 1px, transparent 0); background-size: 32px 32px;"
        >
        </div>
        <div
          class="absolute top-0 -right-32 w-[400px] sm:w-[500px] lg:w-[700px] h-[400px] sm:h-[500px] lg:h-[700px] bg-brand-500/5 rounded-full blur-[120px]"
        >
        </div>
        <div
          class="absolute bottom-0 -left-32 w-[300px] sm:w-[400px] h-[300px] sm:h-[400px] bg-amber-500/4 rounded-full blur-[100px]"
        >
        </div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav
          class="flex items-center gap-2 text-sm text-zinc-400 mb-8 reveal"
          style="animation-delay: 0.05s;"
          aria-label="Ruta de navegación"
        >
          <a href="/" class="hover:text-brand-600 transition-colors">Inicio</a>
          <Chevron to="right" class="w-4 h-4" />
          <span class="text-zinc-500">Nosotros</span>
        </nav>

        <!-- Hero card -->
        <div
          class="relative bg-white rounded-4xl sm:rounded-[2.5rem] lg:rounded-[3rem] border border-zinc-200/70 shadow-2xl shadow-zinc-200/40 overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-zinc-50/80 via-white to-brand-50/20 pointer-events-none"
          >
          </div>
          <div
            class="absolute top-0 left-[8%] right-[8%] h-px bg-linear-to-r from-transparent via-brand-400/40 to-transparent"
          >
          </div>

          <div
            class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 xl:gap-16 items-center p-6 sm:p-8 lg:p-12 xl:p-14"
          >
            <!-- Copy -->
            <div class="min-w-0 order-1">
              <div
                class="reveal flex items-center gap-3 mb-6"
                style="animation-delay: 0.1s;"
              >
                <span class="block w-8 h-px bg-brand-500"></span>
                <span
                  class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-600"
                >
                  Nuestra historia
                </span>
              </div>

              <h1
                class="reveal text-[2rem] leading-[1.08] sm:text-4xl lg:text-5xl xl:text-[3.25rem] font-extrabold text-zinc-900 tracking-[-0.02em] mb-6"
                style="animation-delay: 0.15s;"
              >
                Desde 2007,
                <span
                  class="text-transparent bg-clip-text bg-linear-to-r from-brand-500 via-brand-600 to-amber-600"
                >
                  dando forma
                </span>
                a tus ideas
              </h1>

              <p
                class="reveal text-base sm:text-lg text-zinc-500 leading-relaxed mb-6"
                style="animation-delay: 0.22s;"
              >
                Comenzamos a innovar en el mundo de la litografía y hoy somos
                una compañía líder en soluciones creativas para empresas que
                buscan destacar. Cada proyecto es una oportunidad de superar
                expectativas.
              </p>

              <p
                class="reveal text-base text-zinc-400 leading-relaxed mb-8"
                style="animation-delay: 0.28s;"
              >
                En Estilo Gráfico unimos precisión técnica, diseño profesional y
                un trato cercano para convertir conceptos en impresiones de alto
                impacto.
              </p>

              <div class="reveal" style="animation-delay: 0.34s;">
                <a
                  href="/#productos"
                  class="relative inline-flex items-center justify-center px-7 py-3.5 overflow-hidden rounded-full font-bold text-sm sm:text-base text-zinc-900 group"
                >
                  <div
                    class="absolute inset-0 bg-linear-to-r from-brand-500 to-brand-600 transition-transform duration-500 group-hover:scale-105"
                  >
                  </div>
                  <span class="relative z-10 flex items-center gap-2">
                    Conoce nuestros servicios
                    <span
                      class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5"
                    >
                      <Arrow to="right" class="w-4 h-4" />
                    </span>
                  </span>
                </a>
              </div>
            </div>

            <!-- Hero image -->
            <div
              class="relative min-w-0 order-2 mt-8 lg:mt-0 reveal max-w-xs sm:max-w-sm lg:max-w-md mx-auto lg:mx-0 lg:ml-auto"
              style="animation-delay: 0.2s;"
            >
              <div
                class="relative aspect-3/4 rounded-3xl sm:rounded-4xl overflow-hidden"
              >
                <Image
                  src={aboutUs1}
                  alt="Equipo de Estilo Gráfico en nuestro taller de impresión"
                  class="w-full h-full object-cover object-center"
                  loading="eager"
                  fetchpriority="high"
                />
                <div
                  class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl sm:rounded-4xl pointer-events-none"
                >
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Stats strip -->
        <div
          class="relative -mt-4 sm:-mt-6 mx-2 sm:mx-6 lg:mx-10 reveal"
          style="animation-delay: 0.4s;"
        >
          <div
            class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-zinc-200/80 rounded-2xl sm:rounded-3xl overflow-hidden border border-zinc-200/70 shadow-xl shadow-zinc-200/40"
          >
            {
              stats.map(({ value, label }) => (
                <div class="bg-white px-6 py-6 sm:py-7 text-center sm:text-left lg:text-center">
                  <div class="text-3xl sm:text-4xl font-extrabold text-zinc-900 tracking-tight">
                    {value}
                  </div>
                  <div class="text-sm text-zinc-500 mt-1">{label}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ========== MISSION & VISION ========== -->
    <section class="py-16 sm:py-20 lg:py-28 relative bg-zinc-50/60">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 lg:items-stretch">
          <!-- Image column -->
          <div class="lg:col-span-5 flex h-full min-h-[240px] sm:min-h-[280px]">
            <div
              class="relative w-full h-full rounded-3xl sm:rounded-4xl overflow-hidden shadow-2xl shadow-zinc-300/30"
            >
              <Image
                src={aboutUs2}
                alt="Proceso de impresión y producción gráfica de alta calidad"
                class="absolute inset-0 w-full h-full object-cover object-center"
                loading="lazy"
              />
              <div
                class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl sm:rounded-4xl pointer-events-none"
              >
              </div>
            </div>
          </div>

          <!-- Cards column -->
          <div class="lg:col-span-7 flex flex-col gap-6 sm:gap-8 h-full">
            <div
              class="relative bg-white rounded-3xl sm:rounded-4xl p-8 sm:p-10 border border-zinc-200/70 shadow-xl shadow-zinc-200/30 group hover:border-brand-200/60 hover:shadow-2xl transition-all duration-500 overflow-hidden"
            >
              <div
                class="absolute top-0 left-0 right-0 h-1 bg-linear-to-r from-brand-500 to-brand-600 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              >
              </div>
              <div
                class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-brand-500/10 text-brand-600 mb-6"
              >
                <Lightning class="w-7 h-7" />
              </div>
              <h2
                class="text-2xl sm:text-3xl font-extrabold text-zinc-900 mb-4"
              >
                Nuestra misión
              </h2>
              <p class="text-lg text-zinc-500 leading-relaxed">
                Somos una empresa de litografía dedicada a transformar tus ideas
                en impresiones de alta calidad, combinando creatividad y
                tecnología avanzada para ofrecer soluciones personalizadas que
                impulsen tu marca.
              </p>
            </div>

            <div
              class="relative bg-white rounded-3xl sm:rounded-4xl p-8 sm:p-10 border border-zinc-200/70 shadow-xl shadow-zinc-200/30 group hover:border-amber-200/60 hover:shadow-2xl transition-all duration-500 overflow-hidden"
            >
              <div
                class="absolute top-0 left-0 right-0 h-1 bg-linear-to-r from-amber-500 to-brand-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              >
              </div>
              <div
                class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-amber-500/10 text-amber-600 mb-6"
              >
                <Eye class="w-7 h-7" />
              </div>
              <h2
                class="text-2xl sm:text-3xl font-extrabold text-zinc-900 mb-4"
              >
                Nuestra visión
              </h2>
              <p class="text-lg text-zinc-500 leading-relaxed">
                Con más de {yearsSince} años de experiencia en el sector gráfico,
                nos enorgullece ser un referente en impresión y diseño, comprometidos
                con la excelencia, la innovación continua y la satisfacción de nuestros
                clientes.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== VALUES ========== -->
    <section
      class="py-16 sm:py-20 lg:py-28 relative bg-zinc-50/60"
      aria-labelledby="values-heading"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
          <div class="flex items-center justify-center gap-3 mb-6">
            <span class="block w-8 h-px bg-brand-500"></span>
            <span
              class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-600"
            >
              Lo que nos define
            </span>
            <span class="block w-8 h-px bg-brand-500"></span>
          </div>
          <h2
            id="values-heading"
            class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-zinc-900 tracking-tight leading-tight"
          >
            Nuestros valores,
            <span
              class="text-transparent bg-clip-text bg-linear-to-r from-brand-500 to-amber-600"
            >
              nuestra esencia
            </span>
          </h2>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 lg:gap-6"
        >
          {
            values.slice(0, 3).map(({ title, description, Icon }) => (
              <div class="relative bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 border border-zinc-200/70 hover:border-brand-200/60 hover:shadow-xl hover:shadow-zinc-200/30 group transition-all duration-500 hover:-translate-y-1">
                <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-2xl bg-linear-to-br from-brand-500/10 to-amber-500/10 text-brand-600 mb-5 group-hover:scale-110 transition-transform duration-500">
                  <Icon class="w-6 h-6" />
                </div>
                <h3 class="text-lg sm:text-xl font-extrabold text-zinc-900 mb-2">
                  {title}
                </h3>
                <p class="text-sm sm:text-base text-zinc-500 leading-relaxed">
                  {description}
                </p>
              </div>
            ))
          }
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5 lg:gap-6 mt-4 sm:mt-5 lg:mt-6"
        >
          {
            values.slice(3).map(({ title, description, Icon }) => (
              <div class="relative bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 border border-zinc-200/70 hover:border-brand-200/60 hover:shadow-xl hover:shadow-zinc-200/30 group transition-all duration-500 hover:-translate-y-1">
                <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-2xl bg-linear-to-br from-brand-500/10 to-amber-500/10 text-brand-600 mb-5 group-hover:scale-110 transition-transform duration-500">
                  <Icon class="w-6 h-6" />
                </div>
                <h3 class="text-lg sm:text-xl font-extrabold text-zinc-900 mb-2">
                  {title}
                </h3>
                <p class="text-sm sm:text-base text-zinc-500 leading-relaxed">
                  {description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <ContactBanner
    headline="¿Listo para transformar tus ideas en realidad?"
    subtext="Contáctanos y descubre cómo podemos ayudarte con tus necesidades de impresión y diseño."
  />
  <Footer />
</Layout>

<style>
  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reveal {
    animation: reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
