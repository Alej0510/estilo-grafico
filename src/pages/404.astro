---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Página no encontrada"
  description="La página que buscas no existe. Vuelve al inicio de Estilo Gráfico."
  path="/404"
  noindex={true}
>
  <main class="min-h-[90vh] flex items-center justify-center px-4 pt-32 pb-20">
    <div class="text-center max-w-lg">
      <p
        class="text-brand-600 font-semibold tracking-wide uppercase text-sm mb-4"
      >
        Error 404
      </p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
        Página no encontrada
      </h1>
      <p class="text-white/70 text-lg mb-8">
        La página que buscas no existe o fue movida. Regresa al inicio para
        explorar nuestros servicios.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-brand-500 text-zinc-900 font-semibold hover:bg-brand-400 transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </main>
</Layout>
